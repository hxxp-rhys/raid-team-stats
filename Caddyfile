# Caddy reverse proxy for production. The TLS strategy is chosen by TLS_MODE in
# .env.prod and injected via the imported tls.caddy snippet, which is written by
# caddy-entrypoint.sh at startup:
#   TLS_MODE=acme      automatic HTTPS via Let's Encrypt (default)
#   TLS_MODE=custom    your own cert + key in ./certs, named by SSL_CERT_FILENAME
#                      / SSL_KEY_FILENAME (e.g. a Cloudflare Origin cert; pair it
#                      with the Cloudflare SSL/TLS mode set to Full (strict))
#   TLS_MODE=internal  Caddy self-signed certificate
# Replace {$APP_HOST} via env at deploy time.

{$APP_HOST} {
	# The tls directive is generated from TLS_MODE (see caddy-entrypoint.sh).
	# An explicit cert (custom/internal) automatically disables ACME for the site.
	import /config/tls.caddy

	encode zstd gzip

	# Belt-and-braces: the Next.js app already emits these, but the proxy
	# layer is the authoritative perimeter.
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-origin"
		-Server
		-X-Powered-By
	}

	# Block dotfile access and well-known sensitive paths at the edge.
	@dotfiles path_regexp \/\..*
	respond @dotfiles 404

	# Reverse proxy to the Next.js app container. Trust X-Forwarded-* only from
	# this internal hop — set RATE_LIMIT_TRUST_PROXY=true in the app env.
	reverse_proxy web:3000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto https
	}

	log {
		output stdout
		format json
		level INFO
	}
}

# The public recruitment form is served by `web` at /apply/<guildId>/<slug> on
# {$APP_HOST} above — no separate apply.* subdomain.
