// Prisma 7 schema for raid-team-stats.
// Foundation tables only (Phase 1 + Phase 2 auth surface). Phase 3+ tables added later.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────────────────────────────────────
// Auth.js v5 — Prisma adapter schema (User / Account / Session / VerificationToken)
// access_token, refresh_token, id_token are encrypted at the application layer
// before insert via a Prisma client extension. They remain TEXT here.
// ──────────────────────────────────────────────────────────────────────────────

model User {
  id                    String    @id @default(cuid())
  // Nullable: a user who signs up via Battle.net has no email (Battle.net's
  // OAuth exposes only `sub` + `battle_tag`). They can add + verify an email
  // later for password login. Postgres permits multiple NULLs under a unique
  // index, so email-less Battle.net users don't collide.
  // Encrypted at rest (AES-256-GCM via the @/lib/db extension). Random IV per
  // write means you can't look up by `email` directly — use `emailIndex`.
  email                 String?
  // Blind index for exact-match email lookups: a keyed HMAC of the normalized
  // email (server/auth/email-index.ts), auto-derived on every write by the db
  // extension. The UNIQUE here replaces the old @unique on `email`.
  emailIndex            String?   @unique
  emailVerified         DateTime?
  displayName           String?
  avatarUrl             String?
  mfaEnabled            Boolean   @default(false)
  // Platform-wide admin flag. Authoritative source for "always admin" along
  // with env.ADMIN_USER_IDS / env.ADMIN_EMAILS (see isPlatformAdmin).
  isAdmin               Boolean   @default(false)
  // Bearer token the companion uploader / addon-export endpoint uses to
  // authenticate without a browser session. Null until the user generates
  // one on the setup page; regenerable (invalidates the old one).
  uploadToken           String?   @unique
  // Rolling token rotation for the companion uploader: on each successful
  // upload the server mints a new token, demotes the old one to `Prev` (honored
  // once as a grace window so a dropped response self-heals), and records when
  // it last rotated / was last used (surfaced on the Account page).
  uploadTokenPrev       String?   @unique
  uploadTokenRotatedAt  DateTime?
  uploadTokenLastUsedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  credential     Credential?
  mfaSecret      MfaSecret?
  auditLogsActor AuditLog[]  @relation("AuditLogActor")

  characters          Character[]
  companionStatus     CompanionStatus?
  guildMemberships    GuildMembership[]
  membershipApprovals GuildMembership[]    @relation("GuildMembershipApprover")
  guildsClaimed       Guild[]              @relation("GuildClaimedBy")
  raidTeamsLed        RaidTeam[]           @relation("RaidTeamLeader")
  raidTeamAdditions   RaidTeamMembership[] @relation("RaidTeamMemberAddedBy")
  dashboardsOwned     DashboardConfig[]    @relation("DashboardOwner")
  addonUploads        AddonUpload[]
  eventSignups        EventSignup[]

  // Recruitment (Part 3)
  recruitmentFormsCreated RecruitmentForm[]
  recruitmentApplications FormSubmission[]
  formReviewerRoles       FormReviewer[]
  submissionVotes         SubmissionVote[]
  submissionComments      SubmissionComment[]
  recruitNotifyPrefs      RecruitmentNotificationPref[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────────────────────────────────────
// Local credentials (password) and MFA. Kept separate from Auth.js Account model
// so that OAuth-only or password-only users are both representable cleanly.
// ──────────────────────────────────────────────────────────────────────────────

model Credential {
  userId        String    @id
  passwordHash  String
  lastChangedAt DateTime  @default(now())
  failedLogins  Int       @default(0)
  lockedUntil   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MfaSecret {
  userId        String    @id
  secret        String // AES-256-GCM ciphertext (TOTP secret)
  recoveryCodes String[] // bcrypt-hashed recovery codes
  enabledAt     DateTime?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────────────────────────────────────
// Audit log — append-only record of security-relevant events.
// Never updated, never deleted (retention policy enforced by separate retention job).
// ──────────────────────────────────────────────────────────────────────────────

enum AuditEvent {
  AUTH_LOGIN_SUCCESS
  AUTH_LOGIN_FAILURE
  AUTH_LOGOUT
  AUTH_PASSWORD_CHANGE
  AUTH_PASSWORD_RESET_REQUEST
  AUTH_PASSWORD_RESET_COMPLETE
  AUTH_MFA_ENABLED
  AUTH_MFA_DISABLED
  AUTH_BATTLENET_LINKED
  AUTH_BATTLENET_UNLINKED
  AUTH_DISCORD_LINKED
  AUTH_DISCORD_UNLINKED
  USER_CREATED
  USER_DELETED
  GUILD_CREATED
  GUILD_CLAIMED
  GUILD_ROLE_CHANGED
  MEMBER_APPROVED
  MEMBER_DEPARTED
  RAID_TEAM_CREATED
  RAID_TEAM_MEMBER_ADDED
  RAID_TEAM_MEMBER_REMOVED
  RAID_TEAM_MEMBER_RANK_CHANGED
  RAID_TEAM_LEADERSHIP_TRANSFERRED
  RAID_TEAM_SETTINGS_UPDATED
  RAID_TEAM_WCL_SOURCE_CHANGED
  RAID_TEAM_WCL_SOURCE_DATA_CLEARED
  ADMIN_USER_PROMOTED
  ADMIN_USER_DEMOTED
  ADMIN_SETTINGS_UPDATED
  DASHBOARD_EXPORTED
  SYNC_TRIGGERED
  SYNC_FAILED
  RATE_LIMIT_EXCEEDED
  AUTHZ_DENIED
  CALENDAR_EVENT_CREATED
  CALENDAR_EVENT_UPDATED
  CALENDAR_EVENT_CANCELLED
  CALENDAR_SIGNUP_CHANGED
  CALENDAR_ROSTER_LOCKED
  RECRUITMENT_FORM_DELETED
}

model AuditLog {
  id          BigInt     @id @default(autoincrement())
  event       AuditEvent
  actorUserId String?
  subjectType String? // e.g. "user", "guild", "raidTeam", "character", "dashboard"
  subjectId   String?
  ipHash      String? // SHA-256 of (ip + daily salt) — never the raw IP
  userAgent   String?
  metadata    Json?
  createdAt   DateTime   @default(now())

  actor User? @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([event, createdAt])
  @@index([actorUserId, createdAt])
  @@index([subjectType, subjectId, createdAt])
}

// ──────────────────────────────────────────────────────────────────────────────
// Phase 3 — guilds, characters, raid teams.
//
// A `Guild` is uniquely identified by (region, realmSlug, guildSlug, faction).
// Never key by name alone — multiple guilds across realms/factions share names.
//
// Each Battle.net-linked `Character` belongs to one `User` (the BattleTag
// owner). Guild membership is materialised as `GuildCharacterLink` (per-
// character history) plus `GuildMembership` (per-user role).
//
// `RaidTeam` is a subset of a guild's members — the actual raid roster the
// raid leader curates. Stat dashboards (Phase 5) belong to raid teams.
// ──────────────────────────────────────────────────────────────────────────────

enum Region {
  US
  EU
  KR
  TW
}

enum Faction {
  ALLIANCE
  HORDE
  NEUTRAL
}

enum GuildClaimStatus {
  UNCLAIMED
  GM_CLAIMED
  ADMIN_CLAIMED
}

enum GuildMemberRole {
  OWNER
  OFFICER
  MEMBER
  PENDING
}

enum GuildMembershipStatus {
  ACTIVE
  PENDING
  DEPARTED
}

enum GuildCharacterLinkStatus {
  ACTIVE
  DEPARTED
}

enum RaidTeamVisibility {
  TEAM
  GUILD
  LINK
}

enum RaidTeamMemberRole {
  LEADER
  CO_LEADER
  MEMBER
}

// A raider's standing on the team — distinct from RaidTeamMemberRole (which is
// a site PERMISSION tier). This is the roster rank an officer assigns: a Raid
// Leader runs the raid, an Officer helps lead, a Main is a core raider, a Trial
// is on probation, a Flex/Rotational swaps in and out, a Social is in the team's
// orbit but not a raiding seat. Nullable = unassigned. (New values are appended
// to match Postgres ALTER TYPE ADD VALUE; dropdown order is UI-controlled.)
enum RaidRank {
  MAIN
  TRIAL
  FLEX
  ROTATIONAL
  SOCIAL
  OFFICER
  RAID_LEADER
}

model Character {
  id                  String   @id @default(cuid())
  userId              String
  blizzardCharacterId BigInt   @unique
  region              Region
  realmSlug           String
  name                String
  classId             Int?
  race                String?
  faction             Faction
  level               Int?
  lastSyncedAt        DateTime @default(now())
  createdAt           DateTime @default(now())

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  guildLinks            GuildCharacterLink[]
  raidMemberships       RaidTeamMembership[]
  characterSnapshots    CharacterSnapshot[]
  equipmentSnapshots    EquipmentSnapshot[]
  mplusSnapshots        MplusSnapshot[]
  raidSnapshots         RaidSnapshot[]
  vaultSnapshots        VaultSnapshot[]
  wclParseSnapshots     WclParseSnapshot[]
  professionSnapshots   ProfessionSnapshot[]
  // Pending-ownership back-references. Filled when the team/dashboard's
  // current owner has departed the guild and there is no on-site successor —
  // the first user to claim this character via Battle.net verification gets
  // ownership transferred (see applyVerification → claimPendingAssets).
  pendingRaidTeams      RaidTeam[]             @relation("RaidTeamPendingLeader")
  pendingDashboards     DashboardConfig[]      @relation("DashboardPendingOwner")
  addonUpload           AddonUpload?
  wclReportActors       WclReportActor[]
  wclFightDeaths        WclFightDeath[]
  wclAvoidableDamage    WclAvoidableDamage[]
  raidNightObservations RaidNightObservation[]
  eventSignups          EventSignup[]

  @@unique([region, realmSlug, name])
  @@index([userId])
}

model Guild {
  id              String           @id @default(cuid())
  region          Region
  realmSlug       String
  guildSlug       String
  name            String
  faction         Faction
  // Resolved Warcraft Logs guild id for THIS guild (lazy-cached by GRS via
  // guildData.guild(name, serverSlug, serverRegion){ id }). The default log
  // source for raid teams without an explicit override. Null = not yet
  // resolved or the guild has no WCL presence.
  wclGuildId      Int?
  claimStatus     GuildClaimStatus @default(UNCLAIMED)
  claimedByUserId String?
  claimedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  claimedBy             User?                  @relation("GuildClaimedBy", fields: [claimedByUserId], references: [id], onDelete: SetNull)
  memberships           GuildMembership[]
  characterLinks        GuildCharacterLink[]
  raidTeams             RaidTeam[]
  wclReports            WclReport[]
  wclAvoidableDamage    WclAvoidableDamage[]
  wclAvoidableState     WclAvoidableState[]
  raidNightObservations RaidNightObservation[]
  recruitmentForms      RecruitmentForm[]

  // Identity is region+realm+guild slug ONLY. A guild is a single faction;
  // keeping `faction` in this key let a per-character faction misread mint
  // a DUPLICATE guild row and split the roster, so faction is now a plain
  // attribute, not part of the unique identity.
  @@unique([region, realmSlug, guildSlug])
  @@index([claimStatus])
}

model GuildMembership {
  id               String                @id @default(cuid())
  userId           String
  guildId          String
  role             GuildMemberRole       @default(MEMBER)
  status           GuildMembershipStatus @default(PENDING)
  joinedAt         DateTime              @default(now())
  approvedAt       DateTime?
  approvedByUserId String?
  departedAt       DateTime?

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild      Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  approvedBy User? @relation("GuildMembershipApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, guildId])
  @@index([guildId, status])
}

model GuildCharacterLink {
  id                  String                   @id @default(cuid())
  characterId         String
  guildId             String
  rosterRank          Int?
  firstSeenAt         DateTime                 @default(now())
  lastSeenAt          DateTime                 @default(now())
  status              GuildCharacterLinkStatus @default(ACTIVE)
  consecutiveAbsences Int                      @default(0)
  rejoinedAt          DateTime?
  departedAt          DateTime?

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  guild     Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([characterId, guildId])
  @@index([guildId, status])
}

model RaidTeam {
  id                       String             @id @default(cuid())
  guildId                  String
  name                     String
  slug                     String
  // Optional — null when the team's leader has departed the guild and the
  // platform has no on-site account to transfer leadership to. In that case
  // `pendingLeaderCharacterId` points to the Blizzard character that SHOULD
  // own this team; the first real user to claim that character (via Battle.net
  // verification) inherits leadership.
  leaderUserId             String?
  pendingLeaderCharacterId String?
  visibility               RaidTeamVisibility @default(TEAM)
  // Team-self-service refresh: when true, any active team member can trigger
  // a fresh Tier-A sync via the in-dashboard data_refresh widget. When false,
  // only LEADER/CO_LEADER (or guild OWNER/OFFICER) can refresh.
  memberCanRefresh         Boolean            @default(false)
  // Recurring auto-refresh policy. JSON shapes:
  //   { kind: "interval", hours: 4|6|12|24|28|72 }
  //   { kind: "weekly", dayOfWeek: 0..6, hour: 0..23, minute: 0..59 }
  // null = no auto-refresh (Tier A still runs hourly globally for tracked
  // members; this is a per-team additional opt-in trigger).
  refreshSchedule          Json?
  // Per-team Warcraft Logs source override. Null = inherit the guild's
  // resolved WCL guild (Guild.wclGuildId). Set when a team logs under a
  // different WCL guild (e.g. a team-specific WCL guild entity). The name
  // is captured at save time from the validation probe, for display.
  wclGuildId               Int?
  wclGuildName             String?
  lastRefreshAt            DateTime?
  // Calendar: team home timezone (IANA, e.g. "Europe/London"). Series/events
  // store wall-clock + this tz so a 19:00 raid stays 19:00 local across DST.
  timezone                 String?            @default("UTC")
  // Optional saved comp target for the readiness meter, e.g.
  //   { "tanks": 2, "healers": 5, "melee": 7, "ranged": 6 }
  compTemplate             Json?
  // Calendar auto-reminders. JSON shape:
  //   { "enabled": true, "leadMinutes": [1440, 60], "nudgeMinutes": [720, 360] }
  // leadMinutes  = minutes-before-start to remind people who are GOING;
  // nudgeMinutes = LIST of minutes-before to nudge non-responders ([] = none).
  // A legacy scalar nudgeMinutes (number|null) from the pre-multi-nudge version
  // is still accepted and coerced by parseReminderConfig. null column = defaults.
  reminderConfig           Json?
  // When true, a valid calendar share link serves this team's calendar
  // READ-ONLY to anonymous visitors (no sign-in required). Off by default:
  // links route, they don't grant access. Flipping it off re-locks every
  // outstanding link instantly (checked fresh at resolve time). Distinct from
  // DashboardConfig.shareIsPublic — the calendar share is its own subsystem.
  calendarShareIsPublic    Boolean            @default(false)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  guild              Guild                @relation(fields: [guildId], references: [id], onDelete: Cascade)
  leader             User?                @relation("RaidTeamLeader", fields: [leaderUserId], references: [id], onDelete: SetNull)
  pendingLeader      Character?           @relation("RaidTeamPendingLeader", fields: [pendingLeaderCharacterId], references: [id], onDelete: SetNull)
  memberships        RaidTeamMembership[]
  dashboards         DashboardConfig[]
  raidEventSeries    RaidEventSeries[]
  raidEvents         RaidEvent[]
  discordIntegration DiscordIntegration?
  recruitmentForms   RecruitmentForm[]

  @@unique([guildId, slug])
  @@index([leaderUserId])
  @@index([pendingLeaderCharacterId])
}

model RaidTeamMembership {
  id            String             @id @default(cuid())
  raidTeamId    String
  characterId   String
  role          RaidTeamMemberRole @default(MEMBER)
  rank          RaidRank?
  addedAt       DateTime           @default(now())
  addedByUserId String?
  isActive      Boolean            @default(true)
  removedAt     DateTime?
  removalReason String?

  raidTeam  RaidTeam  @relation(fields: [raidTeamId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  addedBy   User?     @relation("RaidTeamMemberAddedBy", fields: [addedByUserId], references: [id], onDelete: SetNull)

  @@unique([raidTeamId, characterId])
  @@index([characterId, isActive])
  @@index([raidTeamId, isActive])
}

// ──────────────────────────────────────────────────────────────────────────────
// Phase 4 — per-domain immutable snapshots.
//
// Each snapshot row is the canonical record of one observation from one
// upstream source (Blizzard / Warcraft Logs / Raider.IO). `sourceHash` lets
// the ingestion worker dedup re-runs that produce identical data. `rawPayload`
// keeps the source JSON for replay when an upstream schema drifts.
//
// Indexes are tuned for the dashboard read pattern: "give me the latest N
// rows for character X" via (characterId, capturedAt DESC).
// ──────────────────────────────────────────────────────────────────────────────

enum SnapshotSource {
  BLIZZARD
  WARCRAFT_LOGS
  RAIDERIO
}

model CharacterSnapshot {
  id          String         @id @default(cuid())
  characterId String
  capturedAt  DateTime       @default(now())
  source      SnapshotSource
  sourceHash  String
  itemLevel   Int?
  level       Int?
  specId      Int?
  specName    String?
  loadoutText String?
  rawPayload  Json
  createdAt   DateTime       @default(now())

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, capturedAt(sort: Desc)])
  @@index([characterId, source, capturedAt(sort: Desc)])
}

model EquipmentSnapshot {
  id                   String         @id @default(cuid())
  characterId          String
  capturedAt           DateTime       @default(now())
  source               SnapshotSource
  sourceHash           String
  itemLevel            Int?
  missingEnchantsCount Int?
  missingGemsCount     Int?
  tierSetPiecesCount   Int?
  tierSetIds           Int[]          @default([])
  // Per-slot tier breakdown for the dominant tier set:
  //   [{ slot: "HEAD"|"SHOULDER"|"CHEST"|"HANDS"|"LEGS",
  //      filled: boolean, itemLevel: number|null, track: string|null }]
  tierSlots            Json?
  items                Json
  rawPayload           Json
  createdAt            DateTime       @default(now())

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, capturedAt(sort: Desc)])
}

/// Per-character professions snapshot (Blizzard /professions). Stores a compact
/// derived list the Professions widget renders directly, plus the full payload
/// for replay. Shape of `professions`:
///   { primaries:   [ProfEntry], secondaries: [ProfEntry] }
///   ProfEntry = { id, name, kind: "primary"|"secondary",
///                 current: { tierName, skill, max, knownRecipes } | null }
/// `current` is the CURRENT-EXPANSION tier (resolved by name), or null when the
/// character hasn't leveled this expansion's tier (legacy non-tiered professions
/// like Archaeology fall back to their profession-level skill).
model ProfessionSnapshot {
  id          String         @id @default(cuid())
  characterId String
  capturedAt  DateTime       @default(now())
  source      SnapshotSource
  sourceHash  String
  professions Json
  rawPayload  Json
  createdAt   DateTime       @default(now())

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, capturedAt(sort: Desc)])
}

model MplusSnapshot {
  id                   String         @id @default(cuid())
  characterId          String
  capturedAt           DateTime       @default(now())
  source               SnapshotSource
  sourceHash           String
  seasonId             Int
  currentRating        Decimal?       @db.Decimal(8, 2)
  weeklyHighest        Int?
  // Exact count of M+ completions since the weekly reset (repeats included),
  // capped-accurate in the 0–8 band that drives Great Vault slot unlocks.
  // null = not yet computed (pre-migration rows).
  weeklyRunCount       Int?
  // Raider.IO current-season M+ score breakdown (the canonical community
  // number): { all, dps, healer, tank, spec_0.. } — null if RIO unavailable.
  rioScore             Json?
  // Raider.IO PREVIOUS-season overall score + its season slug — the
  // season-over-season churn signal for the engagement_pulse widget. Slug
  // kept because "previous" can cross an expansion boundary (TWW S3 →
  // Midnight S1), where lower scores are structural, not disengagement.
  previousSeasonRating Decimal?       @db.Decimal(8, 2)
  previousSeasonSlug   String?
  runsThisWeek         Json
  rawPayload           Json
  createdAt            DateTime       @default(now())

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, capturedAt(sort: Desc)])
  @@index([characterId, seasonId, capturedAt(sort: Desc)])
}

model RaidSnapshot {
  id             String         @id @default(cuid())
  characterId    String
  capturedAt     DateTime       @default(now())
  source         SnapshotSource
  sourceHash     String
  expansionId    Int?
  tierId         Int?
  completions    Json
  // Raider.IO season-cumulative raid_progression for the current raid:
  // { summary, total_bosses, normal_bosses_killed, heroic_bosses_killed,
  //   mythic_bosses_killed } — distinct from `completions` (weekly lockout).
  seasonProgress Json?
  rawPayload     Json
  createdAt      DateTime       @default(now())

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, capturedAt(sort: Desc)])
}

model VaultSnapshot {
  id          String         @id @default(cuid())
  characterId String
  capturedAt  DateTime       @default(now())
  source      SnapshotSource
  sourceHash  String
  weekStart   DateTime
  slots       Json
  rawPayload  Json
  createdAt   DateTime       @default(now())

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, weekStart])
  @@index([characterId, capturedAt(sort: Desc)])
}

model WclParseSnapshot {
  id               String         @id @default(cuid())
  characterId      String
  capturedAt       DateTime       @default(now())
  source           SnapshotSource
  sourceHash       String
  zoneId           Int
  encounterId      Int
  encounterName    String?
  difficulty       Int
  // Season/partition best percentile for this (encounter,difficulty) —
  // powers the heatmap (current-tier best per boss).
  percentile       Int?
  // Best percentile among kills logged in the CURRENT raid week, plus the
  // epoch of that kill's report. Null when there's no logged kill this
  // week. Powers the "current week only" parses widget.
  weekPercentile   Int?
  reportStartTime  DateTime?
  // Consistency numbers (parse_consistency widget). Per-encounter season
  // MEDIAN percentile, plus the zone-level best/median performance averages
  // — fetched in the same zoneRankings response we always paid for but
  // discarded until now. Nullable: rows predating the widget lack them.
  medianPercentile Float?
  bestAvg          Float?
  medianAvg        Float?
  metric           String?
  reportCode       String?
  rawPayload       Json
  createdAt        DateTime       @default(now())

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, encounterId, difficulty, capturedAt(sort: Desc)])
}

// ── Guild Report Sync (GRS) — per-pull WCL combat-log ingestion ──────────
// One hourly BullMQ job per guild discovers the guild's public WCL reports
// for the current raid zone and persists per-pull fight rows. All spend
// happens in the job; widgets (prog_curve and successors) read ONLY these
// tables at request time. Reports re-fetch while `revision` keeps changing
// or until 48h after the report ends, then freeze forever.
model WclReport {
  id              String    @id @default(cuid())
  code            String    @unique
  guildId         String
  // The report's own zone id (from Report.zone) — never hard-coded so a
  // mid-season raid addition (e.g. Sporefall, possibly a NEW zone id) keeps
  // working without a code change.
  zoneId          Int?
  // The WCL guild id this report was DISCOVERED under (the team/guild log
  // source). Null = member-parse-swept (found via a member's rank report
  // codes, not a guild listing) — those are shared guild-wide and gated to
  // teams by roster participation at read time.
  wclGuildId      Int?
  title           String?
  startTime       DateTime
  endTime         DateTime
  revision        Int
  frozen          Boolean   @default(false)
  fetchedAt       DateTime
  // When the deaths layer was last fetched for this report (any result, incl.
  // zero deaths). Null = never attempted — distinguishes a genuinely
  // death-free report from an un-backfilled one so the backfill sweep doesn't
  // re-fetch death-free reports forever.
  deathsFetchedAt DateTime?
  createdAt       DateTime  @default(now())

  guild  Guild            @relation(fields: [guildId], references: [id], onDelete: Cascade)
  fights WclFight[]
  actors WclReportActor[]
  deaths WclFightDeath[]

  @@index([guildId, startTime(sort: Desc)])
}

// One raid-encounter pull. M+/trash fights are dropped at ingest
// (killType: Encounters + keystoneLevel filter). Fight rows are replaced
// wholesale whenever their report is re-fetched (live logs grow).
model WclFight {
  id                      String   @id @default(cuid())
  reportCode              String
  fightId                 Int
  encounterId             Int
  difficulty              Int
  kill                    Boolean
  size                    Int?
  // Boss HP % remaining at the end of the pull (0 on kills).
  bossPct                 Float?
  // Overall fight % remaining incl. phase weighting — the default Y axis.
  fightPct                Float?
  lastPhase               Int?
  lastPhaseIsIntermission Boolean?
  // Absolute wall-clock pull window (report epoch + fight offsets).
  startAt                 DateTime
  endAt                   DateTime
  durationMs              Int
  // Report-local actor ids present in the pull (joins to WclReportActor).
  friendlyPlayerIds       Int[]    @default([])

  report WclReport @relation(fields: [reportCode], references: [code], onDelete: Cascade)

  @@unique([reportCode, fightId])
  @@index([encounterId, difficulty, startAt(sort: Desc)])
}

// Report-local actor table (players only), with a best-effort join to our
// Character rows by (name, normalized server, guild region). Unmatched
// actors keep characterId null — shown as "unmatched", never dropped.
model WclReportActor {
  id          String  @id @default(cuid())
  reportCode  String
  actorId     Int
  name        String
  server      String?
  subType     String?
  characterId String?

  report    WclReport  @relation(fields: [reportCode], references: [code], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@unique([reportCode, actorId])
  @@index([characterId])
}

// One death within a raid-encounter pull — the first_death_ledger deaths
// layer. Sourced from WCL `events(dataType: Deaths)` (the ordered spine) +
// `table(dataType: Deaths)` (overkill / killing ability). Replaced wholesale
// with its parent report, exactly like WclFight (live logs grow). Ordering
// within a (reportCode, fightId) by `deathOrder` gives first/early-death rank.
model WclFightDeath {
  id                        String    @id @default(cuid())
  reportCode                String
  fightId                   Int
  encounterId               Int
  difficulty                Int
  // The fight's kill status — kill-pull deaths are kept separate from wipes.
  kill                      Boolean
  // Report-local actor ids (join WclReportActor.actorId); characterId is the
  // resolved roster join (null = unmatched, mirrors WclReportActor).
  targetActorId             Int
  characterId               String?
  killerActorId             Int?
  killingAbilityGameId      Int?
  // Killing-ability display name from the table drill-down (nullable: the
  // table call is best-effort and never blocks the events spine).
  killingAbilityName        String?
  // Absolute wall-clock (report epoch + event timestamp) + the 0-based index
  // within the pull by ascending timestamp (precomputed so the read is pure).
  deathAt                   DateTime
  deathOrder                Int
  // Overkill (killing blow minus remaining HP) from the table; null if
  // unmatched. BigInt — overkill can exceed 2^31 on big hits.
  overkill                  BigInt?
  // Battle-rez (combat resurrection) economy: if this death was followed by a
  // rez of the SAME target later in the SAME pull, when + who cast it + which
  // rez spell. Null = stayed dead. Set by the GRS rez pass matching each
  // `events(dataType: Casts)` combat-rez to the most-recent prior unmatched
  // death of its target. A rez with no later re-death of that target = a
  // SUCCESSFUL rez (the brez-efficiency signal), tracked at read time.
  rezzedAt                  DateTime?
  rezzerActorId             Int?
  rezAbilityGameId          Int?
  // Cooldown-usage layer (cooldown_usage widget). For each death we record
  // whether the dying player had a PERSONAL defensive buff active at the moment
  // of death, and the most-recent personal defensive CAST before the death this
  // pull. All from WCL Buffs/Casts events filtered to the defensive allowlist
  // (src/lib/defensive-cooldowns.ts). `defensiveActive*` = an allowlisted buff
  // whose window spanned deathAt (null = none active). `lastDefensiveCast*` =
  // the most-recent self-cast allowlisted defensive before death + ms before
  // (null = none cast this pull). `cooldownsFetchedAt` is the self-healing
  // backfill marker (mirrors WclReport.deathsFetchedAt) — stamped even at 0
  // rows so a processed death drops out of the backfill permanently.
  defensiveActiveGameId     Int?
  defensiveActiveName       String?
  lastDefensiveCastId       Int?
  lastDefensiveCastMsBefore Int?
  cooldownsFetchedAt        DateTime?

  report    WclReport  @relation(fields: [reportCode], references: [code], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@unique([reportCode, fightId, targetActorId, deathAt])
  @@index([encounterId, difficulty, deathAt(sort: Desc)])
  @@index([characterId])
  @@index([reportCode])
  // Backfill sweep: find deaths whose cooldown layer hasn't been computed yet.
  @@index([cooldownsFetchedAt])
}

// Avoidable-damage enrichment for the learning_curve widget. One row per
// (guild, encounter, difficulty, early|late bucket, killing-ability, char):
// that character's total damage TAKEN from that auto-curated avoidable ability
// across the bucket's wipe pulls. The killing abilities come from
// WclFightDeath.killingAbilityGameId (abilities that kill people ARE the
// avoidable mechanics — no hand-curation). Aggregated per guild over the
// rolling window, recomputed wholesale per (encounter,difficulty) by the GRS
// avoidable sweep when its wipe set changes (gated by WclAvoidableState).
model WclAvoidableDamage {
  id            String   @id @default(cuid())
  guildId       String
  encounterId   Int
  difficulty    Int
  // 0 = early half, 1 = late half (chronological split of the enc's wipes).
  bucket        Int
  abilityGameId Int
  characterId   String
  // Total damage taken from this ability across the bucket's pulls. BigInt —
  // summed damage over many pulls easily exceeds 2^31.
  total         BigInt
  computedAt    DateTime @default(now())

  guild     Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([guildId, encounterId, difficulty, bucket, abilityGameId, characterId], map: "WclAvoidableDamage_full_unique")
  @@index([guildId, encounterId, difficulty])
}

// One row per (guild, encounter, difficulty): when its avoidable-damage
// aggregate was last computed + the wipe count then, so the GRS avoidable
// sweep only recomputes when the wipe set changed (cheap change-detector).
model WclAvoidableState {
  id          String   @id @default(cuid())
  guildId     String
  encounterId Int
  difficulty  Int
  computedAt  DateTime
  wipeFights  Int

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, encounterId, difficulty])
}

// Latest payload uploaded by our own in-game addon (via the companion
// uploader or copy/paste). This is the ONLY authoritative source for the
// World/Delve Great Vault row (no Blizzard web API exposes it). One row
// per character, upserted on each upload. `payload` keeps the full raw
// JSON for replay; the derived columns power the widgets directly.
model AddonUpload {
  id              String   @id @default(cuid())
  characterId     String   @unique
  userId          String
  collectedAt     DateTime // in-game time the snapshot was taken
  receivedAt      DateTime @default(now())
  addonVersion    String?
  // Great Vault unlocked-slot counts (0-3 each), derived server-side from
  // the weekly-reward activities the addon captured.
  raidUnlocked    Int?
  mplusUnlocked   Int?
  worldUnlocked   Int?
  worldTotal      Int      @default(3)
  weeklyMplusRuns Int?
  // Equipped item level the addon read directly from the live client
  // (gear.equippedItemLevel). Addon-primary source for the displayed iLvL
  // when the capture is fresh; the Blizzard API iLvL stays the fallback.
  addonItemLevel  Int?
  payload         Json

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Per-USER companion (desktop uploader) install telemetry. One row per user,
// upserted by the /uploader/event endpoint the companion pings on
// install/uninstall. `installed` is the live state; `installedAt` is stamped
// once (first install) and never cleared; `uninstalledAt` records the most
// recent uninstall. `lastSeenVersion`/`lastSeenAddonVersion` are the companion
// app + in-game addon versions reported on the last install event.
// `notifiedUpdateVersion` is reserved for a Phase 3 "email once when an update
// is available" flow. Install state is per-User (the companion is a per-account
// desktop app); the roster widget joins it via Character.userId, so every
// character of the same user shows the same install state.
model CompanionStatus {
  userId                String    @id
  installed             Boolean   @default(false)
  installedAt           DateTime?
  uninstalledAt         DateTime?
  lastSeenVersion       String?
  lastSeenAddonVersion  String?
  notifiedUpdateVersion String?
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────────────────────────────────────
// Phase 4 — ingestion bookkeeping. Tracks per-character sync timestamps and
// per-source budget consumption for ops visibility.
// ──────────────────────────────────────────────────────────────────────────────

model SyncRun {
  id           String         @id @default(cuid())
  tier         String // "A" | "B" | "C"
  source       SnapshotSource
  guildId      String?
  characterId  String?
  startedAt    DateTime       @default(now())
  finishedAt   DateTime?
  ok           Boolean        @default(false)
  errorMessage String?
  metrics      Json?

  @@index([tier, startedAt(sort: Desc)])
  @@index([guildId, startedAt(sort: Desc)])
}

// ──────────────────────────────────────────────────────────────────────────────
// Phase 5 — customizable dashboards, scoped to a RaidTeam.
// `visibility` mirrors RaidTeam.visibility and cannot be more permissive than
// the team's; enforced at the tRPC layer.
// ──────────────────────────────────────────────────────────────────────────────

model DashboardConfig {
  id                      String             @id @default(cuid())
  raidTeamId              String
  ownerUserId             String?
  pendingOwnerCharacterId String?
  name                    String
  slug                    String
  visibility              RaidTeamVisibility @default(TEAM)
  // When true, a valid share link serves this dashboard READ-ONLY to
  // anonymous visitors (no sign-in / guild membership required). Off by
  // default: share links route, they don't grant access. Flipping it off
  // re-locks every outstanding link instantly (checked at resolve time).
  shareIsPublic           Boolean            @default(false)
  layout                  Json
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  raidTeam     RaidTeam   @relation(fields: [raidTeamId], references: [id], onDelete: Cascade)
  owner        User?      @relation("DashboardOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  pendingOwner Character? @relation("DashboardPendingOwner", fields: [pendingOwnerCharacterId], references: [id], onDelete: SetNull)

  @@unique([raidTeamId, slug])
  @@index([raidTeamId])
  @@index([ownerUserId])
  @@index([pendingOwnerCharacterId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Raid Calendar & Attendance (design: docs/design/raid-calendar-attendance.md)
// Website = single source of truth. Every mutation writes the authoritative row
// AND a SyncOutbox row in ONE transaction; a worker fans changes out to the
// website (poll/SSE), Discord, and the companion. Clients send INTENTS, the
// server resolves and versions; LWW by server receipt (SyncOutbox.id order).
// ─────────────────────────────────────────────────────────────────────────────

enum AttendanceState {
  CONFIRM
  TENTATIVE
  LATE
  ABSENT
  // NO_RESPONSE is intentionally NOT a value — it is the absence of a row,
  // derived against the active roster, never persisted per non-responder.
}

enum SignupSource {
  WEBSITE
  DISCORD
  ADDON
  LEADER // a leader set someone else's status on their behalf
}

enum RaidEventStatus {
  PLANNED
  LOCKED // roster locked / final selection made
  CANCELLED
}

enum RosterSelection {
  STARTER
  BENCH
  CUT
}

enum OutboxStatus {
  PENDING
  DISPATCHED
}

/// A recurring raid schedule (e.g. Tue/Wed 19:00). Stores LOCAL wall-clock +
/// IANA timezone, never a fixed offset, so a 19:00 raid stays 19:00 local
/// across DST. A daily materializer turns this into concrete RaidEvent rows for
/// a rolling window.
model RaidEventSeries {
  id                 String    @id @default(cuid())
  raidTeamId         String
  title              String
  difficulty         String // "Mythic" | "Heroic" | "Normal" | "LFR"
  byday              String[] // RFC5545 BYDAY, e.g. ["TU","WE"]
  startLocal         String // wall-clock "19:00" in `timezone`
  durationMin        Int
  timezone           String // IANA, e.g. "Europe/London"
  raidSize           Int?
  notes              String?
  // Raid-lead targeting. `targetOrder` (JSON ordered list of {type,id,zoneId})
  // is authoritative: the planned kill order of whole zones and/or single
  // bosses. The flat arrays below are DERIVED from it for back-compat; null
  // targetOrder = a pre-migration row (readers fall back to the arrays). Drives
  // the month-view zone-art (first two entries). Empty = untargeted.
  targetOrder        Json?
  targetZoneIds      Int[]     @default([])
  targetEncounterIds Int[]     @default([])
  startsOn           DateTime?
  endsOn             DateTime? // null = open-ended; materializer caps to window
  createdByUserId    String?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  raidTeam RaidTeam    @relation(fields: [raidTeamId], references: [id], onDelete: Cascade)
  events   RaidEvent[]

  @@index([raidTeamId, isActive])
}

/// A concrete raid occurrence — owns a stable id that signups, a Discord
/// message id, an outbox stream and a version hang off.
model RaidEvent {
  id                 String          @id @default(cuid())
  raidTeamId         String
  seriesId           String? // null = one-off
  title              String
  difficulty         String
  raidSize           Int? // Mythic-Flex 15–25 (optional)
  startsAt           DateTime        @db.Timestamptz(6) // resolved UTC instant (sort/display/conflict)
  durationMin        Int
  timezone           String // resolved-from tz (so DST changes can re-derive)
  localTime          String // "19:00" wall-clock the occurrence was derived from
  occurrenceDate     String // "2026-06-16" local date — STABLE re-derive/materialize key
  notes              String?
  // Raid-lead targeting. `targetOrder` (JSON ordered list of {type,id,zoneId})
  // is authoritative: the planned kill order of whole zones and/or single
  // bosses. The flat arrays below are DERIVED from it for back-compat; null
  // targetOrder = a pre-migration row (readers fall back to the arrays). Drives
  // the month-view zone-art (first two entries). Empty = untargeted.
  targetOrder        Json?
  targetZoneIds      Int[]           @default([])
  targetEncounterIds Int[]           @default([])
  status             RaidEventStatus @default(PLANNED)
  rosterLockedAt     DateTime?
  // When true this occurrence was edited (or cancelled) for itself alone — the
  // materializer and series-level edits MUST NOT overwrite or resurrect it.
  // One-off events (seriesId = null) are unaffected by this flag.
  seriesOverride     Boolean         @default(false)
  createdByUserId    String?

  // Per-surface delivery linkage (Discord edit-in-place; filled in Phase 2)
  discordGuildId    String?
  discordChannelId  String?
  discordMessageId  String?
  discordRepostLock String?

  version   Int      @default(0) // monotonic per-event; bumped on any change
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  raidTeam  RaidTeam         @relation(fields: [raidTeamId], references: [id], onDelete: Cascade)
  series    RaidEventSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  signups   EventSignup[]
  reminders SentReminder[]

  @@unique([seriesId, occurrenceDate]) // stable materialization key (NOT startsAt)
  @@index([raidTeamId, startsAt])
  @@index([startsAt])
}

/// One signup per (event, character). characterId is REQUIRED (default the
/// caller's primary membership char) — no NULL hole, so dedup/idempotency hold.
model EventSignup {
  id              String           @id @default(cuid())
  raidEventId     String
  userId          String // resolved actor (always known)
  characterId     String // REQUIRED
  state           AttendanceState
  etaMinutes      Int? // LATE
  reason          String? // ABSENT/TENTATIVE optional reason
  comment         String?
  selection       RosterSelection? // leader final-pick (bench/lock)
  source          SignupSource
  updatedByUserId String? // self, or leader id if source=LEADER
  version         Int              @default(0) // per-signup monotonic — THE CAS counter
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  event     RaidEvent @relation(fields: [raidEventId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([raidEventId, characterId])
  @@index([raidEventId, state])
  @@index([userId])
}

/// One OBSERVED raid session, uploaded by an in-game addon observer (the
/// attendance_ledger widget's presence feeder — no public API exposes who was
/// actually in a raid group). One row per (observer character, session): the
/// addon accumulates per-member first/last-seen + sample counts client-side
/// and re-uploads the growing session, so this is UPSERTED by the unique key
/// (the latest upload is the most complete). Presence is unioned across
/// observers at read time. Signups stay first-party (EventSignup); this layer
/// adds who actually SHOWED. `members`/`guildOnline` are compact JSON arrays.
model RaidNightObservation {
  id                  String   @id @default(cuid())
  guildId             String
  observerCharacterId String
  uploadedByUserId    String
  // The addon's session id (its start epoch as a string) — stable across the
  // re-uploads of one raid night so they upsert the same row.
  sessionId           String
  startedAt           DateTime
  endedAt             DateTime
  instanceName        String?
  difficulty          String?
  // [{ name, realm?, firstSeen, lastSeen, samples, online?, subgroup?, role?, class? }]
  // epochs are seconds; name may be "Name" or "Name-Realm".
  members             Json
  // Optional enrichment: guild members seen online during the session (names)
  // — distinguishes "absent (offline)" from "online but not in the raid".
  guildOnline         Json?
  capturedAt          DateTime @default(now())

  guild    Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  observer Character @relation(fields: [observerCharacterId], references: [id], onDelete: Cascade)

  @@unique([observerCharacterId, sessionId])
  @@index([guildId, startedAt(sort: Desc)])
}

/// Append-only event log written in the SAME transaction as every mutation.
/// id is the ordering AND the poll/SSE event id.
model SyncOutbox {
  id             BigInt       @id @default(autoincrement())
  raidTeamId     String
  raidEventId    String?
  kind           String // "event.created"|"event.updated"|"event.cancelled"|"signup.changed"
  payload        Json // full new authoritative state slice
  version        Int // the event/signup version this carries
  idempotencyKey String
  status         OutboxStatus @default(PENDING)
  createdAt      DateTime     @default(now())

  @@index([status, id]) // relay drain
  @@index([raidTeamId, id]) // per-team replay by cursor (poll + SSE)
}

/// Idempotency ledger — INSERT ... ON CONFLICT DO NOTHING; 0 rows ⇒ already
/// applied ⇒ no new outbox row.
model ProcessedIntent {
  idempotencyKey String   @id // sha256(userId:eventId:clientActionId)
  raidEventId    String?
  userId         String?
  version        Int?
  processedAt    DateTime @default(now())
}

/// Per-consumer delivery cursor — ONLY for bounded consumers (discord,
/// companion:<userId>). Browsers carry their cursor client-side (?since=).
model DeliveryCursor {
  id           String   @id @default(cuid())
  consumer     String // "discord" | "companion:<userId>"
  raidTeamId   String
  lastOutboxId BigInt   @default(0)
  updatedAt    DateTime @updatedAt

  @@unique([consumer, raidTeamId])
}

/// Exactly-once ledger for auto-reminder emails. The reminder sweep CLAIMS a
/// row here (unique (event, kind, user)) BEFORE sending — so a reminder fires
/// at most once per recipient even across worker restarts or replicas, with
/// the DB constraint (not a lock) as the authority. `kind` is "lead:<minutes>"
/// (sent to people who are going) or "nudge" (one no-response prompt/event).
model SentReminder {
  id          String   @id @default(cuid())
  raidEventId String
  kind        String
  userId      String
  sentAt      DateTime @default(now())

  raidEvent RaidEvent @relation(fields: [raidEventId], references: [id], onDelete: Cascade)

  @@unique([raidEventId, kind, userId])
  @@index([raidEventId])
}

/// Per-team Discord binding: which guild + channel the bot posts raid embeds
/// into, plus reminder config. One row per team. The Discord-user ↔ site-user
/// binding is NOT here — that reuses the existing Account(provider="discord")
/// row (@@unique([provider, providerAccountId])).
model DiscordIntegration {
  id                   String   @id @default(cuid())
  raidTeamId           String   @unique
  guildId              String // Discord guild snowflake
  channelId            String // channel where event embeds post
  // Auto-post is OPT-IN (default off): when off, raids only reach the channel
  // via the manual "Post to Discord" button. When on, each raid auto-posts once
  // it's within `autoPostLeadDays` of starting (so a recurring schedule shows
  // the upcoming raids, not the whole 8-week horizon at once).
  autoPostEnabled      Boolean  @default(false)
  autoPostLeadDays     Int      @default(5)
  reminderLeadsMinutes Int[]    @default([1440, 240]) // 24h + 4h non-responder nudges
  reminderMode         String   @default("CHANNEL") // "CHANNEL" | "DM"
  // Role gate (two INDEPENDENT roles, each null = open for its surface):
  //  - requiredRoleId gates `/statsmith link` (admins always bypass).
  //  - buttonRoleId gates the signup BUTTONS. When set, a member may tap if they
  //    hold the buttonRole OR the requiredRoleId (link role) OR are an admin.
  //    Null buttonRole = buttons open to anyone.
  requiredRoleId       String? // link-command role snowflake, or null for open
  buttonRoleId         String? // signup-button role snowflake, or null for open
  installedByUserId    String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  raidTeam RaidTeam @relation(fields: [raidTeamId], references: [id], onDelete: Cascade)
}

/// Short-lived, single-use code that binds a Discord snowflake to a site user.
/// The website issues a code; `/statsmith link code:<CODE>` validates (unexpired
/// + unconsumed), atomically burns it (consumedAt), and writes the Account row.
/// Distinct from share-token.ts (B3): 10-min TTL, single-use, user-scoped,
/// individually revocable without rotating AUTH_SECRET.
model DiscordLinkCode {
  code       String    @id // short, single-use (e.g. 8 base32 chars)
  userId     String // the site user requesting the link
  consumedAt DateTime? // burn-on-use (replay-proof)
  expiresAt  DateTime // SHORT TTL (10 minutes)
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ──────────────────────────────────────────────────────────────────────────────
// Recruitment forms (Part 3) — a config-driven, brandable public application
// form per guild/team, an officer review inbox, optional reviewer voting, and
// per-reviewer opt-in notifications. The public submit surface runs in its own
// hardened container (APP_ROLE=recruit-public); officer review lives in the
// main app gated by assertRaidTeamRole / assertGuildRole. Field/branding
// shapes live in src/lib/recruitment/form-schema.ts (the validated JSON).
// ──────────────────────────────────────────────────────────────────────────────

enum RecruitFormStatus {
  DRAFT
  OPEN
  CLOSED
  ARCHIVED
}

enum RecruitSubmissionStatus {
  NEW
  UNDER_REVIEW
  TRIAL_OFFERED
  ACCEPTED
  DECLINED
  WITHDRAWN
}

enum RecruitReviewerRole {
  REVIEWER
  LEAD
}

enum RecruitVoteValue {
  STRONG_NO
  NO
  YES
  STRONG_YES
  ABSTAIN
}

enum RecruitVoteSource {
  WEB
  DISCORD
}

enum RecruitNotifyChannel {
  EMAIL
  DISCORD_DM
}

enum RecruitNotifyKind {
  NEW_SUBMISSION
  STATUS_CHANGE
  QUORUM_REACHED
}

model RecruitmentForm {
  id              String            @id @default(cuid())
  guildId         String
  // Optionally scoped to a team; null = guild-wide form.
  raidTeamId      String?
  name            String
  // Public path segment; the form is reachable at /apply/<slug> only while
  // status = OPEN (a CLOSED/DRAFT form re-locks the link instantly).
  slug            String
  status          RecruitFormStatus @default(DRAFT)
  // Config-driven structure: { version, pages:[{id,title,fields:[…]}], layout,
  // antiSpam, settings }. Validated by src/lib/recruitment/form-schema.ts.
  schema          Json
  // Bumped on every PUBLISHED edit; each submission stamps the version it was
  // taken under so old submissions always render with their original fields.
  schemaVersion   Int               @default(1)
  // Branding object: { logoUrl, coverImageUrl, background, colors, font,
  // welcome, thankYou, faviconUrl }. Null = default theme.
  theme           Json?
  // Voting is OFF by default (the user's explicit requirement); votingConfig
  // holds { quorum, threshold, hideUntilVoted, allowAbstain } when enabled.
  votingEnabled   Boolean           @default(false)
  votingConfig    Json?
  createdByUserId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  guild       Guild                         @relation(fields: [guildId], references: [id], onDelete: Cascade)
  raidTeam    RaidTeam?                     @relation(fields: [raidTeamId], references: [id], onDelete: Cascade)
  createdBy   User?                         @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  submissions FormSubmission[]
  reviewers   FormReviewer[]
  notifyPrefs RecruitmentNotificationPref[]

  @@unique([guildId, slug])
  @@index([raidTeamId])
  @@index([status])
}

model FormSubmission {
  id               String                  @id @default(cuid())
  formId           String
  // Which schema version rendered this submission (stable inbox rendering).
  schemaVersion    Int
  status           RecruitSubmissionStatus @default(NEW)
  // A DRAFT (browser save-and-resume) is never reviewed and never notifies.
  isDraft          Boolean                 @default(false)
  // Anonymous applicants have null; a signed-in/Discord-linked applicant is
  // attributed.
  applicantUserId  String?
  // Denormalized answers snapshot (rendered against schemaVersion) for the
  // single-view; FormAnswer rows power the inbox table/filter/export.
  answersJson      Json
  // A short label (applicant name/BattleTag) pulled from a designated field,
  // for inbox lists + notifications.
  applicantLabel   String?
  // Hashed submitter IP for rate-limit / soft-dedup — never the raw IP.
  ipHash           String?
  submittedAt      DateTime?
  // Discord relay linkage — the per-applicant embed + (when voting is on) the
  // vote buttons, edited in place (mirrors RaidEvent's discordMessageId).
  discordChannelId String?
  discordMessageId String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  form      RecruitmentForm     @relation(fields: [formId], references: [id], onDelete: Cascade)
  applicant User?               @relation(fields: [applicantUserId], references: [id], onDelete: SetNull)
  answers   FormAnswer[]
  votes     SubmissionVote[]
  comments  SubmissionComment[]

  @@index([formId, status])
  @@index([formId, submittedAt(sort: Desc)])
}

// One row per answered field — queryable for inbox table/filter/sort/export.
model FormAnswer {
  id           String  @id @default(cuid())
  submissionId String
  // Matches a Field.id in the form's schema JSON.
  fieldId      String
  // Denormalized for rendering/export without re-reading the schema.
  fieldType    String
  // Polymorphic value — the column matching the field type is populated;
  // valueJson holds arrays (multi-select) + structured values.
  valueText    String? @db.Text
  valueNumber  Float?
  valueJson    Json?

  submission FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([fieldId])
}

// Who may review a form's submissions, beyond the implicit officer access
// (assertRaidTeamRole CO_LEADER / assertGuildRole OFFICER). An explicit grant
// lets a team add a non-officer reviewer (e.g. a trial lead).
model FormReviewer {
  id      String              @id @default(cuid())
  formId  String
  userId  String
  role    RecruitReviewerRole @default(REVIEWER)
  addedAt DateTime            @default(now())

  form RecruitmentForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([formId, userId])
  @@index([userId])
}

// One ordinal vote per reviewer per submission (upserted — last vote wins),
// with a required rationale. Tally + hide-until-voted live in the read layer.
model SubmissionVote {
  id             String            @id @default(cuid())
  submissionId   String
  reviewerUserId String
  value          RecruitVoteValue
  rationale      String            @db.Text
  source         RecruitVoteSource @default(WEB)
  version        Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  submission FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer   User           @relation(fields: [reviewerUserId], references: [id], onDelete: Cascade)

  @@unique([submissionId, reviewerUserId])
  @@index([submissionId])
}

model SubmissionComment {
  id           String   @id @default(cuid())
  submissionId String
  authorUserId String
  body         String   @db.Text
  createdAt    DateTime @default(now())

  submission FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  author     User           @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

// Per-reviewer OPT-IN notification preference (the user's explicit
// requirement). A row exists only when a reviewer has opted in. `channel` =
// EMAIL or DISCORD_DM (user's choice). `formId` null = all forms in scope.
model RecruitmentNotificationPref {
  id             String               @id @default(cuid())
  userId         String
  formId         String?
  channel        RecruitNotifyChannel
  onNew          Boolean              @default(true)
  onStatusChange Boolean              @default(false)
  onQuorum       Boolean              @default(false)

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  form RecruitmentForm? @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([userId, formId, channel])
  @@index([formId])
}

// Notification outbox (decoupled, mirrors the calendar SyncOutbox pattern): a
// row is written in the submit transaction; the worker drains it, fans out to
// opted-in reviewers' channels + the team Discord, and stamps processedAt.
model RecruitmentNotificationOutbox {
  id           String            @id @default(cuid())
  submissionId String
  kind         RecruitNotifyKind
  createdAt    DateTime          @default(now())
  processedAt  DateTime?
  attempts     Int               @default(0)

  @@index([processedAt])
  @@index([submissionId])
}

// Persisted WCL `worldData` snapshot — one row per WCL zone (raids, M+ seasons,
// delves). Refreshed on a schedule by runWorldDataRefresh() so the app holds a
// LOCAL, durable source of truth for the live raid tier + every zone's boss
// list, instead of a hand-maintained WCL_RAID_ZONE_ID env pin that silently
// goes stale each content patch. The single row with isCurrentRaid=true is the
// live raid tier the zone resolver reads (env pin, if set, still overrides).
model WclZone {
  id            Int      @id // WCL zone id (natural key — stable external id)
  name          String
  frozen        Boolean  @default(false) // true once WCL retires the tier
  expansionId   Int?
  expansionName String?
  isRaid        Boolean  @default(false) // difficulties include a raid id (3/4/5)
  isCurrentRaid Boolean  @default(false) // the ONE live raid tier (job-maintained)
  difficulties  Json // [{ id, name }] — WCL difficulty ids (raid 3/4/5, M+ 10, …)
  encounters    Json // [{ id, name }] — WCL encounter ids (matches parse rows)
  refreshedAt   DateTime // last refresh of this row from WCL worldData
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([frozen])
  @@index([isCurrentRaid])
}

// Singleton admin-configurable policy/customization settings (id pinned to
// "singleton" — there is exactly one row, auto-created on first read). Only the
// admin-gated `settings` router reads/writes it. Retention values are in DAYS;
// null = keep forever (no auto-prune). Defaults follow audit-log best practice
// (short-lived ops logs, longer-lived security/audit trail).
model AdminSettings {
  id String @id @default("singleton")

  // Retention — DB-enforced by the runRetentionPrune() worker sweep:
  auditLogRetentionDays  Int? @default(90) // AuditLog (security/audit trail)
  syncRunRetentionDays   Int? @default(14) // SyncRun (ingestion job history)
  // Retention — Loki Caddy access/traffic logs: enforced immediately via Loki's
  // delete API + written into the Loki config so the compactor takes over on
  // next restart (then the API call is skipped):
  accessLogRetentionDays Int? @default(30)
  // Retention — Prometheus metrics: written to config for next deploy (startup
  // flag; no runtime API):
  metricsRetentionDays   Int? @default(15)

  // Security-tab thresholds (what counts as a concerning spike to highlight):
  loginFailureAlertThreshold Int @default(20) // failures within the window
  loginFailureWindowMinutes  Int @default(5)

  updatedAt       DateTime @updatedAt
  updatedByUserId String?
}
