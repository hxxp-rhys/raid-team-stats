# Environment configuration for raid-team-stats. Copy to `.env` for local dev.
# Every value validated at boot by src/env.ts. The app will refuse to start
# (in production) if any required value is missing or malformed.

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development                              # development | test | production
APP_URL=http://localhost:3000                     # canonical public URL (no trailing /)

# Locks every Auth.js URL (including OAuth callbacks) to this origin regardless
# of how the request arrived. Required so Battle.net always sees
# https://raiders.hxxp.io/api/auth/callback/battlenet as the redirect_uri.
AUTH_URL=

# Comma-separated extra origins accepted by the tRPC same-origin (CSRF) check.
# Required when the app is served on more than one URL. Example with the dev
# Caddy TLS terminator + the public hostname:
#   TRUSTED_ORIGINS=https://localhost,https://raiders.hxxp.io
TRUSTED_ORIGINS=
LOG_LEVEL=info                                    # trace | debug | info | warn | error | fatal

# ── Database & Cache ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://raid_team_stats:dev_password_change_me@localhost:5432/raid_team_stats?schema=public
# Redis now requires a password — embed REDIS_PASSWORD (below) in the URL.
REDIS_URL=redis://:dev_redis_change_me@localhost:6379
# Redis AUTH password. The redis container starts with `--requirepass` using
# this value, and it MUST match the password embedded in REDIS_URL above.
# Redis caches API tokens + job payloads, so never run it unauthenticated.
# Use a strong unique value in production.
REDIS_PASSWORD=dev_redis_change_me

# ── Secrets ──────────────────────────────────────────────────────────────────
# `openssl rand -base64 48` — used by Auth.js for session signing.
AUTH_SECRET=

# `openssl rand -base64 48` — signs shareable-dashboard links. Optional: falls
# back to AUTH_SECRET when unset. Set a SEPARATE value so you can revoke ALL
# share links (by rotating this) without logging every user out.
SHARE_TOKEN_SECRET=

# `openssl rand -base64 32` — must decode to exactly 32 raw bytes. Master key
# for AES-256-GCM encryption-at-rest of OAuth tokens AND all non-email PII
# (display names, avatars, recruitment answers) — defense-in-depth on top of
# database disk encryption. Required, and must stay STABLE: lose or change it and
# the encrypted columns can no longer be read. To encrypt rows that predate
# encryption, run the one-time backfill (RUN_PII_BACKFILL=true for one deploy, or
# the script directly — see SETUP.md §9).
TOKEN_ENCRYPTION_KEY=

# ── Blizzard Battle.net ──────────────────────────────────────────────────────
# Register an app at https://develop.battle.net/access/clients
# Register BOTH the dev and production redirect URIs in the Battle.net console:
#   http://localhost:3000/bnet-login-callback        (dev)
#   https://your-domain.example/bnet-login-callback  (prod)
BLIZZARD_CLIENT_ID=
BLIZZARD_CLIENT_SECRET=
BLIZZARD_REGION=us                                # us | eu | kr | tw
BATTLENET_REDIRECT_URI=http://localhost:3000/bnet-login-callback

# ── Warcraft Logs (Platinum tier: 18 000 points/hr) ──────────────────────────
# Register at https://www.warcraftlogs.com/api/clients/
# Redirect URI (used by the user-link flow shipped in v1.1):
#   http://localhost:3000/wcl-callback               (dev)
#   https://your-domain.example/wcl-callback         (prod)
WCL_CLIENT_ID=
WCL_CLIENT_SECRET=
WCL_HOURLY_POINTS_BUDGET=17000                    # reserve 1 000 for ad-hoc queries
WCL_REDIRECT_URI=http://localhost:3000/wcl-callback
# OPTIONAL emergency override for the current raid tier's WCL zone id.
# LEAVE BLANK in normal operation: the worker persists the full WCL worldData
# (every zone + boss list) to the DB on boot + every 6h and auto-resolves the
# live raid tier (newest non-frozen zone with raid difficulties), so there's
# nothing to bump each content patch. Only set this to FORCE a specific zone if
# WCL ever mis-resolves — and note it then SUPPRESSES the auto-resolved value
# (the worker logs a drift WARNING if a set pin disagrees with the live tier).
# Find ids via scripts/wcl-smoke.ts.
WCL_RAID_ZONE_ID=

# ── Raider.IO (optional; public endpoints don't require a key) ───────────────
# RAIDERIO_API_KEY=

# ── Email ────────────────────────────────────────────────────────────────────
# Used for account verification, password reset, and raid auto-reminders.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Discord bot (optional — raid calendar integration) ───────────────────────
# Leave blank to disable Discord entirely (the rest of the app is unaffected).
# Create an app at https://discord.com/developers/applications:
#   - General Information → Application ID  → DISCORD_APP_ID
#   - General Information → Public Key       → DISCORD_PUBLIC_KEY
#   - Bot → Reset Token                      → DISCORD_BOT_TOKEN
# Set the Interactions Endpoint URL to: <APP_URL>/uploader/discord/interactions
# Install to a server with scope `bot applications.commands` (NOT Administrator).
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=

# ── Platform admins ──────────────────────────────────────────────────────────
# A user is treated as platform admin (full OWNER/LEADER override + access to
# /admin) if ANY of the following match: their user id is in ADMIN_USER_IDS,
# their verified email is in ADMIN_EMAILS, or User.isAdmin is true in the DB.
# Email-based admin is recommended for bootstrap accounts because it survives
# account deletion + recreation (user.id changes but email stays the same).
ADMIN_USER_IDS=
ADMIN_EMAILS=

# ── Proxy trust ──────────────────────────────────────────────────────────────
# Set to `true` ONLY behind a vetted reverse proxy (Caddy in this repo's prod
# compose). When false, client-supplied X-Forwarded-* headers are stripped.
RATE_LIMIT_TRUST_PROXY=false

# ── Observability ────────────────────────────────────────────────────────────
# Shared bearer that Prometheus uses to scrape /api/metrics. Generate with
# `openssl rand -hex 32`. REQUIRED in production — the app refuses to boot
# without it (fail-closed). When empty in dev, only authenticated platform
# admins can hit /api/metrics in a browser.
METRICS_TOKEN=

# Grafana admin credentials for the dev observability container. The password
# has NO default (the dev stack won't start until you set one). Keep Grafana
# bound to localhost — never expose it publicly.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# ── Branding & homepage customization (ALL OPTIONAL) ─────────────────────────
# Rebrand the site and customize the landing page WITHOUT touching code. These
# are SERVER vars read at RUNTIME, so they work with the pre-built Docker image
# with NO rebuild. Set any you want; leave the rest for the built-in defaults.
#   APP_NAME             Site/product name (header, page titles, emails, MFA).
#   APP_TAGLINE          Short tagline shown under the logo.
#   APP_DESCRIPTION      <meta name="description"> for SEO / social cards.
#   BRAND_LOGO_URL       Header + homepage logo. Point it at a file you mount
#                        into the container's public dir — e.g. set
#                        BRAND_LOGO_URL=/branding/logo.png and add a bind mount
#                        ./branding:/app/public/branding:ro (see SETUP.md §11).
#   HOMEPAGE_HEADLINE    Landing-page hero headline (H1).
#   HOMEPAGE_SUBHEADING  Landing-page hero paragraph.
#   HOMEPAGE_FOOTER_NOTE Small note in the landing-page footer.
# APP_NAME=
# APP_TAGLINE=
# APP_DESCRIPTION=
# BRAND_LOGO_URL=
# HOMEPAGE_HEADLINE=
# HOMEPAGE_SUBHEADING=
# HOMEPAGE_FOOTER_NOTE=

# ── Client-visible (inlined into the bundle at build time) ───────────────────
# Build-time fallback for the site name; used only when APP_NAME (above) is
# unset. For the pre-built image, prefer APP_NAME (it applies at runtime).
NEXT_PUBLIC_APP_NAME=Raid Team Stats
