.claude/

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
persistent_data/

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Test / coverage
/coverage
/.vitest

# Next.js
/.next/
/out/

# Production builds
/build
/dist

# Misc
.DS_Store
Thumbs.db
# TLS certificates + private keys — NEVER commit. Custom-mode cert/key live in
# the host's certs dir (Setup: <DATA_DIR>/certs; prod/dev: ./certs).
*.pem
*.key
certs/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Env files (never commit — see .env.example for documented vars)
.env
.env.*
!.env.example

# Vercel (unused, but in case anyone ever runs `vercel`)
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Prisma generated client
/src/generated

# Editor / IDE
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.code-workspace

# AI-assistant working files (Claude Code skills + local settings/notes) —
# kept on-disk for local use, not tracked in the public repo.
.claude/

# OS metadata
desktop.ini
$RECYCLE.BIN/

# companion uploader local config (contains the user upload token)
companion/config.json

# installer build artifacts (built by installer/build.ps1; deployed out-of-band)
installer/dist/
companion/sea-prep.blob
