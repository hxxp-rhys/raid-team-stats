{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    { "title": "RTS — HTTP Traffic", "type": "link", "url": "/d/rts-http-traffic", "icon": "external link" },
    { "title": "RTS — System Runtime", "type": "link", "url": "/d/rts-system-runtime", "icon": "external link" },
    { "title": "RTS — Security & Auth", "type": "link", "url": "/d/rts-security-auth", "icon": "external link" },
    { "title": "RTS — Ingestion & Logs", "type": "link", "url": "/d/rts-ingestion-logs", "icon": "external link" }
  ],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Process uptime",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 60 }, { "color": "green", "value": 300 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "time() - rts_process_start_time_seconds", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Resident memory (RSS)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rts_process_resident_memory_bytes", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Heap used",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rts_nodejs_heap_size_used_bytes", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Event-loop lag p99",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.2 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rts_nodejs_eventloop_lag_p99_seconds", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU rate (cores)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(rts_process_cpu_user_seconds_total[5m])", "legendFormat": "user", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(rts_process_cpu_system_seconds_total[5m])", "legendFormat": "system", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory: RSS vs heap used",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rts_process_resident_memory_bytes", "legendFormat": "RSS", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rts_nodejs_heap_size_used_bytes", "legendFormat": "heap used", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rts_nodejs_heap_size_total_bytes", "legendFormat": "heap total", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate by status class (req/s)",
      "description": "From Caddy access logs (Loki). The proxy HTTP histogram metric is not emitted, so request rate is derived from logs.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 7,
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 1, "stacking": { "mode": "normal", "group": "A" } } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(rate({container=\"rts-caddy\"} | json | status>=200 and status<300 [1m]))", "legendFormat": "2xx", "refId": "A" },
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(rate({container=\"rts-caddy\"} | json | status>=300 and status<400 [1m]))", "legendFormat": "3xx", "refId": "B" },
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(rate({container=\"rts-caddy\"} | json | status>=400 and status<500 [1m]))", "legendFormat": "4xx", "refId": "C" },
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(rate({container=\"rts-caddy\"} | json | status>=500 [1m]))", "legendFormat": "5xx", "refId": "D" }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP 5xx rate (req/s)",
      "description": "Server errors from Caddy access logs (Loki).",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 8,
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "red" }, "custom": { "drawStyle": "line", "fillOpacity": 30, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "single" } },
      "targets": [
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(rate({container=\"rts-caddy\"} | json | status>=500 [1m]))", "legendFormat": "5xx", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Auth events (rate by event)",
      "description": "rts_auth_events_total appears after the first login; empty until then.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "id": 9,
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(rts_auth_events_total[5m])) by (event)", "legendFormat": "{{event}}", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Rate-limit denials (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "id": 10,
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 50 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(rts_http_rate_limited_total[1h])", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "App error-log rate (web + worker, per min)",
      "description": "Pino-pretty ERROR lines from rts-web and rts-worker (Loki).",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "id": 11,
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(count_over_time({container=\"rts-web\"} |~ \"ERROR\\\\x1b\" [1m]))", "legendFormat": "web errors/min", "refId": "A" },
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(count_over_time({container=\"rts-worker\"} |~ \"ERROR\\\\x1b\" [1m]))", "legendFormat": "worker errors/min", "refId": "B" }
      ]
    },
    {
      "type": "logs",
      "title": "Recent server errors (Caddy 5xx)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "id": 12,
      "options": { "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true, "enableLogDetails": true },
      "targets": [
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "{container=\"rts-caddy\"} | json | status>=500 | line_format \"{{.status}} {{.request_method}} {{.request_host}}{{.request_uri}} dur={{.duration}}s\"", "refId": "A" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["raid-team-stats", "rts"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "RTS — Overview",
  "uid": "rts-overview",
  "version": 2,
  "weekStart": ""
}
