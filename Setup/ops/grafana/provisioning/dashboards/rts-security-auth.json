{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    { "title": "RTS — Overview", "type": "link", "url": "/d/rts-overview", "icon": "external link" }
  ],
  "liveNow": false,
  "panels": [
    {
      "type": "text",
      "title": "About this dashboard",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": { "mode": "markdown", "content": "Auth/security signals from Prometheus (`rts_auth_events_total`, `rts_http_rate_limited_total`) and from Loki access/app logs. **Note:** `rts_auth_events_total{event=...}` only materializes after the first login event — its panels stay empty until then. 401/403 signals come from Caddy access logs (`status`)." }
    },
    {
      "type": "timeseries",
      "title": "Auth events (rate by event)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 3 },
      "id": 2,
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(rts_auth_events_total[5m])) by (event)", "legendFormat": "{{event}}", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Auth events total (by event, 6h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 3 },
      "id": 3,
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(increase(rts_auth_events_total[6h])) by (event)", "legendFormat": "{{event}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rate-limit denials (rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "id": 4,
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "orange" }, "custom": { "drawStyle": "line", "fillOpacity": 25, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "single" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(rts_http_rate_limited_total[5m])", "legendFormat": "rate-limited/s", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Rate-limit denials (1h / 6h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "id": 5,
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 50 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(rts_http_rate_limited_total[1h])", "legendFormat": "last 1h", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(rts_http_rate_limited_total[6h])", "legendFormat": "last 6h", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP 401 / 403 rate (Caddy)",
      "description": "Unauthorized / forbidden responses from Caddy access logs.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 6,
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(rate({container=\"rts-caddy\"} | json | status=401 [1m]))", "legendFormat": "401 unauthorized", "refId": "A" },
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(rate({container=\"rts-caddy\"} | json | status=403 [1m]))", "legendFormat": "403 forbidden", "refId": "B" },
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(rate({container=\"rts-caddy\"} | json | status=429 [1m]))", "legendFormat": "429 too many requests", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Auth/login-related app errors (web)",
      "description": "Pino-pretty ERROR/WARN lines from rts-web that mention auth/login/unauthorized.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 7,
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(count_over_time({container=\"rts-web\"} |~ \"(?i)(auth|login|unauthorized|forbidden|session)\" |~ \"(ERROR|WARN)\\\\x1b\" [1m]))", "legendFormat": "auth errors/min", "refId": "A" }
      ]
    },
    {
      "type": "logs",
      "title": "Recent 401 / 403 / 429 requests (Caddy)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 27 },
      "id": 8,
      "options": { "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true, "enableLogDetails": true },
      "targets": [
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "{container=\"rts-caddy\"} | json | status=~\"401|403|429\" | line_format \"{{.status}} {{.request_method}} {{.request_host}}{{.request_uri}} ip={{.request_remote_ip}}\"", "refId": "A" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["raid-team-stats", "rts", "security"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "RTS — Security & Auth",
  "uid": "rts-security-auth",
  "version": 1,
