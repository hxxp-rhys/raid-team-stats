# ═══════════════════════════════════════════════════════════════════════════
#  raid-team-stats — PRODUCTION environment
#
#  This is the ONLY file you edit. Copy it to ".env" and fill it in:
#
#      cp .env.example .env
#      ./init.sh                  # creates .env, fills every secret/password, prepares storage
#
#  Then set APP_HOST / APP_URL, your Battle.net + Warcraft Logs credentials,
#  and your SMTP details below.
#
#  [REQUIRED]  lines must be set or the stack refuses to start.
#  [OPTIONAL]  lines are safe to leave as-is.
# ═══════════════════════════════════════════════════════════════════════════


# ── Deployment knobs (read by Docker Compose) ──────────────────────────────

# Where ALL persistent data is stored on this host (database, cache, metrics,
# logs, Grafana, TLS certificates). Defaults to ./data next to this file.
# Point it at another disk with an absolute path, e.g. /srv/raidstats/data .
# After changing this, re-run ./init.sh .
DATA_DIR=./data

# Which optional stacks run. Monitoring is ON by default.
#   monitoring          Prometheus + Loki + Promtail + Grafana   (DEFAULT)
#   (empty)             core app only — NO monitoring            (opt out)
#   monitoring,backup   also run the nightly encrypted DB backup
# To OPT OUT of monitoring, set this to empty:   COMPOSE_PROFILES=
COMPOSE_PROFILES=monitoring

# Container image to run. Defaults to the latest published release. To pin an
# exact, reproducible build, uncomment and set a specific tag, e.g.:
#   RTS_IMAGE=ghcr.io/hxxp-rhys/raid-stats:sha-2b9bcf0
# RTS_IMAGE=ghcr.io/hxxp-rhys/raid-stats:latest


# ── TLS / HTTPS (read by Docker Compose) ───────────────────────────────────
# How Caddy obtains the certificate it serves on :443:
#   acme      Automatic HTTPS via Let's Encrypt (DEFAULT). Requires your DNS A
#             record to point at this server and ports 80/443 reachable from the
#             public internet. Do NOT use this if a proxy that terminates TLS
#             (e.g. Cloudflare's orange-cloud) sits in front — ACME cannot
#             validate; use "custom" instead.
#   custom    Use your OWN certificate + key files (a Cloudflare Origin cert, or
#             any commercial / Let's Encrypt cert obtained elsewhere). Put both
#             files in <DATA_DIR>/certs and name them below. Behind Cloudflare,
#             set the Cloudflare SSL/TLS mode to Full (strict).
#   internal  Caddy self-signed cert (local testing, or behind a proxy doing its
#             own TLS that does not validate the origin certificate).
TLS_MODE=acme

# [OPTIONAL] Contact email for Let's Encrypt expiry notices (acme mode only).
ACME_EMAIL=

# [custom mode] Filenames of your certificate + private key inside
# <DATA_DIR>/certs. The certificate file must be the FULL CHAIN (your leaf cert
# followed by any intermediates). After placing or renaming the files, re-run
# ./init.sh so Caddy (root) can read them (the key is locked to 0600).
SSL_CERT_FILENAME=origin.pem
SSL_KEY_FILENAME=origin.key


# ── Core ───────────────────────────────────────────────────────────────────

NODE_ENV=production

# [REQUIRED] Public hostname ONLY — no scheme, no port, no path.
# Caddy serves the site at this hostname; how it gets the TLS certificate is set
# by TLS_MODE above. Must match the host in APP_URL below.
APP_HOST=raid.example.com

# [REQUIRED] Canonical public URL — always https://<APP_HOST> .
APP_URL=https://raid.example.com

# [REQUIRED] Pin Auth.js (incl. OAuth callbacks) to the public origin.
# Set this equal to APP_URL. (Battle.net login fails with invalid_grant if the
# request origin and this value disagree.)
AUTH_URL=https://raid.example.com

# [REQUIRED] Keep "true" — the app sits behind the bundled Caddy reverse proxy.
RATE_LIMIT_TRUST_PROXY=true

# [OPTIONAL] Extra browser origins allowed by the CSRF check (comma-separated).
TRUSTED_ORIGINS=

# [OPTIONAL] trace | debug | info | warn | error | fatal
LOG_LEVEL=info


# ── Database & cache passwords ─────────────────────────────────────────────
# The full DATABASE_URL and REDIS_URL are assembled automatically by Docker
# Compose from these two passwords — you do NOT write a connection string.
# Use hex (URL-safe) values; ./init.sh does this for you.

# [REQUIRED]  openssl rand -hex 24
POSTGRES_PASSWORD=

# [REQUIRED]  openssl rand -hex 24
REDIS_PASSWORD=


# ── App secrets ────────────────────────────────────────────────────────────
# Generate all of these with ./init.sh .

# [REQUIRED] min 32 chars — session signing.   openssl rand -base64 48
AUTH_SECRET=

# [OPTIONAL, recommended] separate signer for shareable-dashboard links so you
# can revoke them without logging everyone out. Falls back to AUTH_SECRET when
# blank.   openssl rand -base64 48
SHARE_TOKEN_SECRET=

# [REQUIRED] must decode to exactly 32 bytes — AES-256-GCM key for encryption
# at rest of OAuth tokens + PII. NEVER change it after first boot or the
# encrypted columns become unreadable.   openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=


# ── Battle.net (Blizzard) OAuth ────────────────────────────────────────────
# Register an app at https://develop.battle.net/access/clients and add the
# redirect URI:   https://<APP_HOST>/api/auth/callback/battlenet
# (the app's built-in callback path — there is no redirect-URI env var)

# [REQUIRED]
BLIZZARD_CLIENT_ID=
# [REQUIRED]
BLIZZARD_CLIENT_SECRET=
# [OPTIONAL] us | eu | kr | tw
BLIZZARD_REGION=us


# ── Warcraft Logs OAuth ────────────────────────────────────────────────────
# Register a client at https://www.warcraftlogs.com/api/clients/ and add the
# redirect URI:   https://<APP_HOST>/wcl-callback

# [REQUIRED]
WCL_CLIENT_ID=
# [REQUIRED]
WCL_CLIENT_SECRET=
# [OPTIONAL] Must match the redirect URI registered above.
WCL_REDIRECT_URI=https://raid.example.com/wcl-callback
# [OPTIONAL] Reserve ~1000 of the hourly points budget for ad-hoc queries.
WCL_HOURLY_POINTS_BUDGET=17000
# [OPTIONAL] Emergency raid-zone pin — leave blank (the worker auto-resolves it).
WCL_RAID_ZONE_ID=


# ── Raider.IO (optional — public endpoints need no key) ────────────────────
# RAIDERIO_API_KEY=


# ── Email (SMTP) — verification, password reset, raid reminders ────────────

# [REQUIRED]
SMTP_HOST=
# [OPTIONAL]
SMTP_PORT=587
# [REQUIRED]
SMTP_USER=
# [REQUIRED]
SMTP_PASSWORD=
# [REQUIRED] e.g.  Raid Stats <noreply@example.com>
SMTP_FROM=


# ── Monitoring ─────────────────────────────────────────────────────────────

# [REQUIRED] Bearer token Prometheus uses to scrape the app's /api/metrics.
# Required even if you opt out of monitoring — the app validates it at boot.
# After changing it, RECREATE Prometheus: docker compose up -d prometheus
# openssl rand -hex 32
METRICS_TOKEN=

# [OPTIONAL] Grafana login. Grafana is bound to localhost; reach it over an SSH
# tunnel. Set a strong password when monitoring is enabled.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# [OPTIONAL] Override only if the app should read from an EXTERNAL Prometheus /
# Loki instead of the bundled ones (defaults already match the bundled stack).
# PROMETHEUS_URL=http://prometheus:9090
# LOKI_URL=http://loki:3100


# ── Discord bot (optional — raid calendar integration) ─────────────────────
# Leave all three blank to disable Discord. To enable, create an app at
# https://discord.com/developers/applications and set all three.

DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=


# ── Platform admins ────────────────────────────────────────────────────────
# A user becomes a platform admin if their user id is in ADMIN_USER_IDS, their
# verified email is in ADMIN_EMAILS, or User.isAdmin is true in the database.
# Email-based admin survives account deletion/recreation, so it's the most
# robust way to bootstrap your first admin.

# [OPTIONAL] comma-separated user ids
ADMIN_USER_IDS=
# [OPTIONAL] comma-separated emails
ADMIN_EMAILS=
# [OPTIONAL] Platform admins are forced to set up MFA. List any admin emails
# here to EXEMPT them — use this to avoid locking out a bootstrap admin.
ADMIN_MFA_EXEMPT=


# ── Branding & homepage (all optional; applied at runtime, no rebuild) ──────
# APP_NAME=
# APP_TAGLINE=
# APP_DESCRIPTION=
# BRAND_LOGO_URL=
# HOMEPAGE_HEADLINE=
# HOMEPAGE_SUBHEADING=
# HOMEPAGE_FOOTER_NOTE=
# AGPL-3.0 section-13: the in-app "Source" link. Leave unset to point at the
# upstream repo. If you MODIFY the code, set this to YOUR fork so you offer your
# users your modified source (an AGPL section-13 obligation).
# SOURCE_REPO_URL=
NEXT_PUBLIC_APP_NAME=Raid Team Stats


# ── Nightly encrypted backups (only used with COMPOSE_PROFILES=…,backup) ────
# Generate the age key pair OFFLINE (age-keygen) and keep the PRIVATE key off
# this host. Configure an rclone remote for off-host upload.
# BACKUP_AGE_PUBKEY=
# RCLONE_REMOTE=
