# Caddy reverse proxy for production. TLS uses a Cloudflare Origin Certificate
# because the origin is proxied through Cloudflare, so ACME/Let's Encrypt
# challenges can't be validated (HTTP-01 -> CF 522, TLS-ALPN-01 -> CF terminates
# TLS). Place the cert/key at data/certs/origin.{pem,key} (mounted read-only at
# /certs) and set the Cloudflare SSL/TLS mode to Full (strict).
# Replace {$APP_HOST} via env at deploy time.

{$APP_HOST} {
	# Cloudflare Origin Certificate — providing an explicit cert disables Caddy's
	# automatic HTTPS/ACME (which cannot succeed behind the Cloudflare proxy).
	tls /certs/origin.pem /certs/origin.key

	encode zstd gzip

	# Belt-and-braces: the Next.js app already emits these, but the proxy
	# layer is the authoritative perimeter.
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-origin"
		-Server
		-X-Powered-By
	}

	# Block dotfile access and well-known sensitive paths at the edge.
	@dotfiles path_regexp \/\..*
	respond @dotfiles 404

	# Reverse proxy to the Next.js app container. Trust X-Forwarded-* only from
	# this internal hop — set RATE_LIMIT_TRUST_PROXY=true in the app env.
	reverse_proxy web:3000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto https
	}

	log {
		output stdout
		format json
		level INFO
	}
}

# The public recruitment form is served by `web` at /apply/<guildId>/<slug> on
# {$APP_HOST} above — no separate apply.* subdomain.
