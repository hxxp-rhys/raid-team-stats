# Dev TLS terminator. Caddy listens on :80 (HTTP, redirect-only) and :443
# (HTTPS, reverse-proxy to the Next.js web service).
#
# Only the two whitelisted hostnames are accepted at the TLS layer:
#   - localhost            (host machine)
#   - raiders.hxxp.io      (Cloudflare-fronted public origin)
# Requests with any other Host header get a 421 "Misdirected Request".
#
# Uses the bind-mounted Cloudflare Origin cert + key from ./certs — the same
# pair a real Cloudflare tunnel would terminate against in production.
# Browsers don't trust Cloudflare Origin certs directly; cert warning at
# https://localhost is expected and goes away once Cloudflare's edge sits
# in front of this origin.

{
	# We supply explicit cert files; don't let Caddy try to ACME-issue.
	auto_https off
	admin off
}

# HTTP listener: redirect everything to HTTPS. The Host header is preserved
# so https://raiders.hxxp.io routing still works after the redirect.
:80 {
	redir https://{host}{uri} permanent
}

# HTTPS listener. Site address listing both hostnames means Caddy will only
# answer for those two; anything else (e.g. a scanner hitting the IP) gets
# 421 and no upstream call.
localhost, raiders.hxxp.io {
	tls /certs/raiders.hxxp.io-crt.pem /certs/raiders.hxxp.io-key.pem

	encode zstd gzip

	reverse_proxy web:3000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Proto https
	}

	log {
		output stdout
		format json
		level INFO
	}
}
