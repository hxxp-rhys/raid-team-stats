# Dev TLS terminator. Caddy reverse-proxies HTTPS to the Next.js web service and
# auto-redirects HTTP->HTTPS. The TLS strategy is chosen by TLS_MODE in .env and
# injected via the imported tls.caddy snippet (written by caddy-entrypoint.sh):
#   TLS_MODE=custom    your cert + key in ./certs (SSL_CERT_FILENAME /
#                      SSL_KEY_FILENAME) — DEFAULT for dev; ships a local
#                      Cloudflare Origin cert (raiders.hxxp.io-crt/-key.pem).
#   TLS_MODE=internal  Caddy self-signed cert (localhost dev).
#   TLS_MODE=acme      Let's Encrypt — only meaningful if a public DNS name
#                      resolves to this host (localhost falls back to internal).
#
# Only the two whitelisted hostnames are answered at the TLS layer:
#   - localhost            (host machine)
#   - raiders.hxxp.io      (Cloudflare-fronted public origin)
# Browsers don't trust Cloudflare Origin certs directly, so a cert warning at
# https://localhost is expected with the default custom cert; it goes away once
# Cloudflare's edge sits in front of this origin.

{
	admin off
}

# HTTPS listener. Listing both hostnames means Caddy answers only for those two;
# it automatically adds the HTTP->HTTPS redirect for them.
localhost, raiders.hxxp.io {
	# The tls directive is generated from TLS_MODE (see caddy-entrypoint.sh).
	import /config/tls.caddy

	encode zstd gzip

	reverse_proxy web:3000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Proto https
	}

	log {
		output stdout
		format json
		level INFO
	}
}

# The public recruitment form is served by `web` at /apply/<guildId>/<slug> on
# the primary host above — no separate `apply.*` subdomain.
