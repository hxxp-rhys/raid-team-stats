# Dev TLS terminator. Caddy listens on :443 inside the container; docker-compose
# maps that to 127.0.0.1:8443 on the host (the plain-HTTP web service stays on
# 3000 for hot-reload tooling that can't speak HTTPS).
#
# Uses the bind-mounted Cloudflare Origin cert + key from ./certs — the same
# pair a real Cloudflare tunnel would terminate against in production.
# Browsers don't trust Cloudflare Origin certs directly, so when hitting
# https://localhost:8443 you'll see a cert warning — that's expected; the
# warning only goes away once Cloudflare's edge is in front of this origin.

{
	# Turn off the global auto-HTTPS upgrade pass: we're already on :443 and
	# don't have a public hostname for ACME issuance in dev.
	auto_https off
	admin off
}

:443 {
	tls /certs/raiders.hxxp.io-crt.pem /certs/raiders.hxxp.io-key.pem

	encode zstd gzip

	reverse_proxy web:3000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Proto https
	}

	log {
		output stdout
		format json
		level INFO
	}
}
