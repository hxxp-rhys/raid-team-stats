<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Stat Smith Uploader"
           Manufacturer="Stat Smith"
           Version="1.0.15.0"
           UpgradeCode="6F2A8E14-3C7B-4D29-9B1E-7A5C2D4F8E10"
           Scope="perMachine"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Property Id="ARPHELPLINK" Value="https://raiders.hxxp.io" />

    <!-- User inputs (set via the custom dialog; sensible defaults). -->
    <Property Id="WOWPATH" Value="C:\Program Files (x86)\World of Warcraft" />
    <Property Id="APIKEY" Secure="yes" />
    <Property Id="RUNATSTARTUP" Value="1" />
    <Property Id="APIBASE" Value="https://raiders.hxxp.io" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="RaidTeamStatsUploader">
        <Directory Id="ADDONSTAGE" Name="addon" />
      </Directory>
    </StandardDirectory>

    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Component Id="CompanionExe">
        <File Id="rts_companion.exe" Source="installer\dist\rts-companion.exe" KeyPath="yes" />
      </Component>
      <Component Id="RunHiddenVbs">
        <File Id="run_hidden.vbs" Source="installer\run-hidden.vbs" KeyPath="yes" />
      </Component>
      <Component Id="ReadmeTxt">
        <File Id="README.txt" Source="installer\README.txt" KeyPath="yes" />
      </Component>
      <Component Id="UploadNowCmd">
        <File Id="upload_now.cmd" Source="installer\upload-now.cmd" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Desktop + Start Menu shortcuts so users never navigate to the
         install dir. Both are MSI components → removed on uninstall. -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="A7E1D2C3-4B56-4789-9ABC-DEF012345678">
        <Shortcut Id="DeskSc" Name="Stat Smith - Upload Now"
                  Target="[INSTALLFOLDER]upload-now.cmd"
                  WorkingDirectory="INSTALLFOLDER"
                  Description="Upload your WoW Great Vault / M+ data now" />
        <RemoveFolder Id="DesktopFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\raid-team-stats\Uploader"
                       Name="desk" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuDir" Name="Stat Smith">
        <Component Id="StartMenuShortcut"
                   Guid="B8F2E3D4-5C67-489A-8BCD-EF0123456789">
          <Shortcut Id="MenuSc" Name="Stat Smith - Upload Now"
                    Target="[INSTALLFOLDER]upload-now.cmd"
                    WorkingDirectory="INSTALLFOLDER"
                    Description="Upload your WoW Great Vault / M+ data now" />
          <Shortcut Id="MenuReadme" Name="Read Me"
                    Target="[INSTALLFOLDER]README.txt" />
          <RemoveFolder Id="AppMenuDir" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\raid-team-stats\Uploader"
                         Name="menu" Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Autostart: a shortcut in the COMMON Startup folder (replaces the
         old, invisible WOW6432Node\Run value as of 1.0.15). Runs in the
         signed-in user's session at EVERY logon, is visible & toggleable
         in Explorer and Task Manager > Startup, and is fully MSI-managed
         (removed on uninstall). rts-companion.exe is GUI-subsystem so it
         runs with NO window. Only present when the user opted in
         (RUNATSTARTUP). An InstallFinalize custom action also launches it
         immediately so it runs the moment setup completes — no need to
         log out/in first. -->
    <StandardDirectory Id="StartupFolder">
      <Component Id="AutostartShortcut"
                 Guid="C9D4E1F2-6A7B-4C8D-9E0F-1A2B3C4D5E6F"
                 Condition="RUNATSTARTUP = &quot;1&quot;">
        <Shortcut Id="StartupSc" Name="Stat Smith Uploader"
                  Target="[INSTALLFOLDER]rts-companion.exe"
                  Arguments="--watch"
                  WorkingDirectory="INSTALLFOLDER"
                  Description="Syncs your WoW data in the background" />
        <RemoveFolder Id="StartupFolder" On="uninstall" />
        <RegistryValue Root="HKLM" Key="Software\raid-team-stats\Uploader"
                       Name="startup" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <ComponentGroup Id="AddonStageFiles" Directory="ADDONSTAGE">
      <Component Id="AddonToc">
        <File Id="StatSmith.toc"
              Source="addon\StatSmith\StatSmith.toc"
              KeyPath="yes" />
      </Component>
      <Component Id="AddonLua">
        <File Id="StatSmith.lua"
              Source="addon\StatSmith\StatSmith.lua"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Feature Id="Main" Title="Stat Smith Uploader" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="AddonStageFiles" />
      <ComponentRef Id="DesktopShortcut" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="AutostartShortcut" />
    </Feature>

    <!-- ───────── validation (immediate, on the config dialog's Next) ───────── -->
    <CustomAction Id="VerifyInputs" BinaryRef="RtsScript" JScriptCall="verifyInputs"
                  Execute="immediate" Return="check" />

    <!-- ───────── deferred work (elevated, after files are laid down) ───────── -->
    <CustomAction Id="SetWriteConfig" Property="WriteConfig"
                  Value="[INSTALLFOLDER]|[APIKEY]|[WOWPATH]|[APIBASE]|[LogonUser]" />
    <CustomAction Id="WriteConfig" BinaryRef="RtsScript" JScriptCall="writeConfig"
                  Execute="deferred" Impersonate="no" Return="check" />

    <CustomAction Id="SetInstallAddon" Property="InstallAddon"
                  Value="[INSTALLFOLDER]|[WOWPATH]" />
    <CustomAction Id="InstallAddon" BinaryRef="RtsScript" JScriptCall="installAddon"
                  Execute="deferred" Impersonate="no" Return="check" />

    <!-- Autostart is a Common-Startup-folder shortcut (AutostartShortcut)
         for subsequent logons; this CA launches it IMMEDIATELY at the end
         of a successful install so it runs the moment setup finishes (no
         log out/in needed). Impersonate=yes → runs in the installing
         user's session (sees their %LOCALAPPDATA% config + WoW folder);
         asyncNoWait → the installer doesn't block on the long-lived
         background watch process. -->
    <CustomAction Id="LaunchCompanion"
                  FileRef="rts_companion.exe"
                  ExeCommand="--watch"
                  Execute="immediate"
                  Impersonate="yes"
                  Return="asyncNoWait" />

    <!-- uninstall: stop the running agent FIRST (so RemoveFiles can delete
         the otherwise-locked exe), also delete any LEGACY scheduled task
         left by pre-1.0.6 builds, then deep-clean. -->
    <CustomAction Id="StopAgent" BinaryRef="RtsScript" JScriptCall="stopAgent"
                  Execute="deferred" Impersonate="no" Return="ignore" />
    <CustomAction Id="SetUninstallClean" Property="UninstallClean"
                  Value="[WOWPATH]|[INSTALLFOLDER]|[LogonUser]" />
    <CustomAction Id="UninstallClean" BinaryRef="RtsScript" JScriptCall="uninstallClean"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <Binary Id="RtsScript" SourceFile="installer\ca.js" />

    <InstallExecuteSequence>
      <Custom Action="StopAgent" Before="RemoveFiles"
              Condition="REMOVE=&quot;ALL&quot;" />
      <Custom Action="SetUninstallClean" Before="UninstallClean"
              Condition="REMOVE=&quot;ALL&quot;" />
      <Custom Action="UninstallClean" After="RemoveFiles"
              Condition="REMOVE=&quot;ALL&quot;" />

      <Custom Action="SetWriteConfig" Before="WriteConfig"
              Condition="NOT REMOVE" />
      <Custom Action="WriteConfig" After="InstallFiles"
              Condition="NOT REMOVE" />

      <Custom Action="SetInstallAddon" Before="InstallAddon"
              Condition="NOT REMOVE" />
      <Custom Action="InstallAddon" After="WriteConfig"
              Condition="NOT REMOVE" />

      <!-- Start the uploader right after a successful install/upgrade
           when the user opted into autostart. -->
      <Custom Action="LaunchCompanion" After="InstallFinalize"
              Condition="NOT REMOVE AND RUNATSTARTUP=&quot;1&quot;" />
    </InstallExecuteSequence>

    <!-- WixUI_InstallDir gives Welcome/License/InstallDir/Verify/Progress.
         The custom RtsConfigDlg (RtsUI.wxs) is chained in after the
         install-location dialog and runs VerifyInputs on its Next. -->
    <ui:WixUI Id="WixUI_InstallDir" />
    <UIRef Id="RtsCustomUI" />
    <WixVariable Id="WixUILicenseRtf" Value="installer\License.rtf" />

  </Package>
</Wix>
