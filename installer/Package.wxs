<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Raid Team Stats Uploader"
           Manufacturer="Raid Team Stats"
           Version="1.0.31.0"
           UpgradeCode="6F2A8E14-3C7B-4D29-9B1E-7A5C2D4F8E10"
           Scope="perMachine"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Property Id="ARPHELPLINK" Value="https://github.com/hxxp-rhys/raid-team-stats" />

    <!-- User inputs (set via the custom dialog; sensible defaults). -->
    <Property Id="WOWPATH" Value="C:\Program Files (x86)\World of Warcraft" />
    <Property Id="APIKEY" Secure="yes" />
    <Property Id="RUNATSTARTUP" Value="1" />
    <!-- Your Raid Stats site URL. NO default - this is a self-hostable app;
         the user enters it in the setup dialog. Secure="yes" (like APIKEY) so
         this public property is set in the UI and carried into the deferred,
         elevated WriteConfig action (an empty, non-Secure Property is ignored
         by WiX -> WIX1006). HTTPS-validated + token-verified against it before
         install, then written into the companion's config.json. -->
    <Property Id="APIBASE" Secure="yes" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <!-- Set to "1" by ReadExistingConfig when a valid per-user config.json
         already exists (i.e. an upgrade/reinstall). Gates skipping the
         site+token dialog AND the config-write, so existing settings are
         reused and never re-prompted. Secure="yes" (like APIBASE/APIKEY): an
         empty non-Secure Property is dropped by WiX (WIX1006), and Secure lets
         the UI-set value cross into the execute sequence. ReadExistingConfig
         re-derives it from disk in BOTH sequences, so a command-line override
         can't force a skip on a real first install. -->
    <Property Id="HAVECONFIG" Secure="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="RaidTeamStatsUploader">
        <Directory Id="ADDONSTAGE" Name="addon" />
      </Directory>
    </StandardDirectory>

    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Component Id="CompanionExe">
        <File Id="rts_companion.exe" Source="installer\dist\rts-companion.exe" KeyPath="yes" />
      </Component>
      <Component Id="TrayExe">
        <File Id="rts_tray.exe" Source="installer\dist\rts-tray.exe" KeyPath="yes" />
      </Component>
      <Component Id="RunHiddenVbs">
        <File Id="run_hidden.vbs" Source="installer\run-hidden.vbs" KeyPath="yes" />
      </Component>
      <Component Id="ReadmeTxt">
        <File Id="README.txt" Source="installer\README.txt" KeyPath="yes" />
      </Component>
      <Component Id="UploadNowCmd">
        <File Id="upload_now.cmd" Source="installer\upload-now.cmd" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Desktop + Start Menu shortcuts so users never navigate to the
         install dir. Both are MSI components → removed on uninstall. -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="A7E1D2C3-4B56-4789-9ABC-DEF012345678">
        <Shortcut Id="DeskSc" Name="Raid Team Stats - Upload Now"
                  Target="[INSTALLFOLDER]upload-now.cmd"
                  WorkingDirectory="INSTALLFOLDER"
                  Description="Upload your WoW Great Vault / M+ data now" />
        <RemoveFolder Id="DesktopFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\raid-team-stats\Uploader"
                       Name="desk" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuDir" Name="Raid Team Stats">
        <Component Id="StartMenuShortcut"
                   Guid="B8F2E3D4-5C67-489A-8BCD-EF0123456789">
          <Shortcut Id="MenuSc" Name="Raid Team Stats - Upload Now"
                    Target="[INSTALLFOLDER]upload-now.cmd"
                    WorkingDirectory="INSTALLFOLDER"
                    Description="Upload your WoW Great Vault / M+ data now" />
          <Shortcut Id="MenuReadme" Name="Read Me"
                    Target="[INSTALLFOLDER]README.txt" />
          <RemoveFolder Id="AppMenuDir" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\raid-team-stats\Uploader"
                         Name="menu" Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Autostart: a shortcut in the COMMON Startup folder (replaces the
         old, invisible WOW6432Node\Run value as of 1.0.15). Runs in the
         signed-in user's session at EVERY logon, is visible & toggleable
         in Explorer and Task Manager > Startup, and is fully MSI-managed
         (removed on uninstall). rts-companion.exe is GUI-subsystem so it
         runs with NO window. Only present when the user opted in
         (RUNATSTARTUP). An InstallFinalize custom action also launches it
         immediately so it runs the moment setup completes — no need to
         log out/in first. -->
    <StandardDirectory Id="StartupFolder">
      <Component Id="AutostartShortcut"
                 Guid="C9D4E1F2-6A7B-4C8D-9E0F-1A2B3C4D5E6F"
                 Condition="RUNATSTARTUP = &quot;1&quot;">
        <Shortcut Id="StartupSc" Name="Raid Team Stats Uploader"
                  Target="[INSTALLFOLDER]rts-companion.exe"
                  Arguments="--watch"
                  WorkingDirectory="INSTALLFOLDER"
                  Description="Syncs your WoW data in the background" />
        <RemoveFolder Id="StartupFolder" On="uninstall" />
        <RegistryValue Root="HKLM" Key="Software\raid-team-stats\Uploader"
                       Name="startup" Type="integer" Value="1" KeyPath="yes" />
      </Component>
      <!-- The system-tray helper (rts-tray.exe) also autostarts: a SEPARATE
           Startup shortcut on the same RUNATSTARTUP gate. Independent of the
           companion (the tray is the UI; the companion keeps syncing even if
           the tray is closed). No second RemoveFolder — the one above already
           cleans the StartupFolder (a duplicate RemoveFolder Id would error). -->
      <Component Id="TrayStartupShortcut"
                 Guid="D1E5F2A3-7B8C-4D9E-AF10-2B3C4D5E6F70"
                 Condition="RUNATSTARTUP = &quot;1&quot;">
        <Shortcut Id="TrayStartupSc" Name="Raid Team Stats Tray"
                  Target="[INSTALLFOLDER]rts-tray.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Description="System-tray controls for Raid Team Stats" />
        <RegistryValue Root="HKLM" Key="Software\raid-team-stats\Uploader"
                       Name="traystartup" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <ComponentGroup Id="AddonStageFiles" Directory="ADDONSTAGE">
      <Component Id="AddonToc">
        <File Id="StatSmith.toc"
              Source="addon\StatSmith\StatSmith.toc"
              KeyPath="yes" />
      </Component>
      <Component Id="AddonLua">
        <File Id="StatSmith.lua"
              Source="addon\StatSmith\StatSmith.lua"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Feature Id="Main" Title="Raid Team Stats Uploader" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="AddonStageFiles" />
      <ComponentRef Id="DesktopShortcut" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="AutostartShortcut" />
      <ComponentRef Id="TrayStartupShortcut" />
    </Feature>

    <!-- ───────── validation (immediate, on the config dialog's Next) ───────── -->
    <CustomAction Id="VerifyInputs" BinaryRef="RtsScript" JScriptCall="verifyInputs"
                  Execute="immediate" Return="check" />

    <!-- immediate + impersonated: read the existing per-user config.json (if
         any) so an upgrade reuses the site/token/WoW-folder and skips the
         re-prompt. Return="ignore" - a read failure must never block setup
         (it just falls back to first-install prompting). -->
    <CustomAction Id="ReadExistingConfig" BinaryRef="RtsScript" JScriptCall="readExistingConfig"
                  Execute="immediate" Impersonate="yes" Return="ignore" />

    <!-- ───────── deferred work (elevated, after files are laid down) ───────── -->
    <CustomAction Id="SetWriteConfig" Property="WriteConfig"
                  Value="[INSTALLFOLDER]|[APIKEY]|[WOWPATH]|[APIBASE]|[LogonUser]|[ProductVersion]" />
    <CustomAction Id="WriteConfig" BinaryRef="RtsScript" JScriptCall="writeConfig"
                  Execute="deferred" Impersonate="no" Return="check" />

    <CustomAction Id="SetInstallAddon" Property="InstallAddon"
                  Value="[INSTALLFOLDER]|[WOWPATH]" />
    <CustomAction Id="InstallAddon" BinaryRef="RtsScript" JScriptCall="installAddon"
                  Execute="deferred" Impersonate="no" Return="check" />

    <!-- Autostart is a Common-Startup-folder shortcut (AutostartShortcut)
         for subsequent logons; this CA launches it IMMEDIATELY at the end
         of a successful install so it runs the moment setup finishes (no
         log out/in needed). Impersonate=yes → runs in the installing
         user's session (sees their %LOCALAPPDATA% config + WoW folder);
         asyncNoWait → the installer doesn't block on the long-lived
         background watch process. -->
    <CustomAction Id="LaunchCompanion"
                  FileRef="rts_companion.exe"
                  ExeCommand="--watch"
                  Execute="immediate"
                  Impersonate="yes"
                  Return="asyncNoWait" />

    <!-- Launch the tray immediately after install too, in the installing
         user's session, without blocking setup. NOTE: a FileRef Exe CA with an
         EMPTY ExeCommand is a malformed type-18 action the Windows Installer
         engine refuses to launch (the tray then only appeared at the NEXT logon
         via TrayStartupShortcut, never right after setup). So this is a
         Directory-based Exe CA whose ExeCommand carries the full quoted exe
         path as a NON-empty command line. -->
    <CustomAction Id="LaunchTray"
                  Directory="INSTALLFOLDER"
                  ExeCommand="&quot;[INSTALLFOLDER]rts-tray.exe&quot;"
                  Execute="immediate"
                  Impersonate="yes"
                  Return="asyncNoWait" />

    <!-- uninstall: stop the running agent FIRST (so RemoveFiles can delete
         the otherwise-locked exe), also delete any LEGACY scheduled task
         left by pre-1.0.6 builds, then deep-clean. -->
    <CustomAction Id="StopAgent" BinaryRef="RtsScript" JScriptCall="stopAgent"
                  Execute="deferred" Impersonate="no" Return="ignore" />
    <!-- The deferred StopAgent above is gated REMOVE=ALL (uninstall only), so a
         major UPGRADE never stopped the running companion/tray - the MSI then
         couldn't replace the locked exes and the user had to kill them in Task
         Manager. This IMMEDIATE, impersonated twin runs stopAgent in the user
         session on any install/upgrade, in the immediate phase BEFORE
         InstallValidate / RemoveExistingProducts / RemoveFiles, so the locked
         exes are killed before file replacement. Return=ignore => harmless
         no-op on a clean first install where nothing is running. -->
    <CustomAction Id="StopRunningForUpgrade" BinaryRef="RtsScript" JScriptCall="stopAgent"
                  Execute="immediate" Impersonate="yes" Return="ignore" />
    <CustomAction Id="SetUninstallClean" Property="UninstallClean"
                  Value="[WOWPATH]|[INSTALLFOLDER]|[LogonUser]" />
    <CustomAction Id="UninstallClean" BinaryRef="RtsScript" JScriptCall="uninstallClean"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <Binary Id="RtsScript" SourceFile="installer\ca.js" />

    <InstallExecuteSequence>
      <!-- Reuse existing config on upgrade (also covers silent installs). Runs
           before SetWriteConfig (gates it) and before SetInstallAddon (provides
           WOWPATH). On a FIRST install config.json doesn't exist yet (WriteConfig
           writes it later), so this is a no-op and the dialog values stand. -->
      <Custom Action="ReadExistingConfig" After="CostFinalize"
              Condition="NOT REMOVE" />
      <!-- Kill any running companion/tray early (immediate phase, after
           ReadExistingConfig, hence after CostFinalize and BEFORE
           InstallValidate) so a major upgrade can replace the otherwise-locked
           exes - this precedes RemoveExistingProducts + RemoveFiles +
           InstallFiles (all of which run in the later deferred script). -->
      <Custom Action="StopRunningForUpgrade" After="ReadExistingConfig"
              Condition="NOT REMOVE" />
      <Custom Action="StopAgent" Before="RemoveFiles"
              Condition="REMOVE=&quot;ALL&quot;" />
      <Custom Action="SetUninstallClean" Before="UninstallClean"
              Condition="REMOVE=&quot;ALL&quot;" />
      <Custom Action="UninstallClean" After="RemoveFiles"
              Condition="REMOVE=&quot;ALL&quot;" />

      <!-- First install only: on upgrade (HAVECONFIG) KEEP the existing
           config.json untouched - it may hold a server-rotated token and the
           autoUpdateAddon flag - instead of overwriting it. -->
      <Custom Action="SetWriteConfig" Before="WriteConfig"
              Condition="NOT REMOVE AND NOT HAVECONFIG" />
      <Custom Action="WriteConfig" After="InstallFiles"
              Condition="NOT REMOVE AND NOT HAVECONFIG" />

      <Custom Action="SetInstallAddon" Before="InstallAddon"
              Condition="NOT REMOVE" />
      <Custom Action="InstallAddon" After="WriteConfig"
              Condition="NOT REMOVE" />

      <!-- Start the uploader right after a successful install/upgrade
           when the user opted into autostart. -->
      <Custom Action="LaunchCompanion" After="InstallFinalize"
              Condition="NOT REMOVE AND RUNATSTARTUP=&quot;1&quot;" />
      <Custom Action="LaunchTray" After="LaunchCompanion"
              Condition="NOT REMOVE AND RUNATSTARTUP=&quot;1&quot;" />
    </InstallExecuteSequence>

    <!-- WixUI_InstallDir gives Welcome/License/InstallDir/Verify/Progress.
         The custom RtsConfigDlg (RtsUI.wxs) is chained in after the
         install-location dialog and runs VerifyInputs on its Next. -->
    <ui:WixUI Id="WixUI_InstallDir" />
    <UIRef Id="RtsCustomUI" />
    <WixVariable Id="WixUILicenseRtf" Value="installer\License.rtf" />

  </Package>
</Wix>
