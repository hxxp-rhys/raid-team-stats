{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    { "title": "RTS — Overview", "type": "link", "url": "/d/rts-overview", "icon": "external link" }
  ],
  "liveNow": false,
  "panels": [
    {
      "type": "text",
      "title": "About this dashboard",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": { "mode": "markdown", "content": "HTTP traffic is derived entirely from **Caddy access logs** in Loki (`container=\"rts-caddy\"`). The proxy request-duration histogram metric is not emitted to Prometheus, so latency here is parsed from the access-log `duration` field. Fields available after `| json`: `status`, `duration`, `request_method`, `request_uri`, `request_host`, `request_remote_ip`." }
    },
    {
      "type": "timeseries",
      "title": "Request rate by status class (req/s)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 3 },
      "id": 2,
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 25, "lineWidth": 1, "stacking": { "mode": "normal", "group": "A" } } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(rate({container=\"rts-caddy\"} | json | status>=200 and status<300 [1m]))", "legendFormat": "2xx", "refId": "A" },
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(rate({container=\"rts-caddy\"} | json | status>=300 and status<400 [1m]))", "legendFormat": "3xx", "refId": "B" },
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(rate({container=\"rts-caddy\"} | json | status>=400 and status<500 [1m]))", "legendFormat": "4xx", "refId": "C" },
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(rate({container=\"rts-caddy\"} | json | status>=500 [1m]))", "legendFormat": "5xx", "refId": "D" }
      ]
    },
    {
      "type": "stat",
      "title": "Total requests (1h)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 3 },
      "id": 3,
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(count_over_time({container=\"rts-caddy\"} | json | __error__=\"\" [1h]))", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "5xx (1h)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 7 },
      "id": 4,
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 25 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(count_over_time({container=\"rts-caddy\"} | json | status>=500 [1h]))", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "4xx & 5xx rate (req/s)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "id": 5,
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 1 } }, "overrides": [ { "matcher": { "id": "byName", "options": "5xx" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }, { "matcher": { "id": "byName", "options": "4xx" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] } ] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(rate({container=\"rts-caddy\"} | json | status>=400 and status<500 [1m]))", "legendFormat": "4xx", "refId": "A" },
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(rate({container=\"rts-caddy\"} | json | status>=500 [1m]))", "legendFormat": "5xx", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request latency (duration percentiles, s)",
      "description": "Parsed from the Caddy access-log duration field via unwrap.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "id": 6,
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "quantile_over_time(0.50, {container=\"rts-caddy\"} | json duration=\"duration\" | unwrap duration [5m])", "legendFormat": "p50", "refId": "A" },
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "quantile_over_time(0.90, {container=\"rts-caddy\"} | json duration=\"duration\" | unwrap duration [5m])", "legendFormat": "p90", "refId": "B" },
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "quantile_over_time(0.99, {container=\"rts-caddy\"} | json duration=\"duration\" | unwrap duration [5m])", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests by method (req/s)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 7,
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(rate({container=\"rts-caddy\"} | json | __error__=\"\" [1m])) by (request_method)", "legendFormat": "{{request_method}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests by host (req/s)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 8,
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(rate({container=\"rts-caddy\"} | json | __error__=\"\" [1m])) by (request_host)", "legendFormat": "{{request_host}}", "refId": "A" }
      ]
    },
    {
      "type": "table",
      "title": "Top URIs (1h)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 27 },
      "id": 9,
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [ { "matcher": { "id": "byName", "options": "Value" }, "properties": [ { "id": "displayName", "value": "requests" }, { "id": "custom.width", "value": 120 } ] } ] },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "requests", "desc": true } ] },
      "targets": [
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "topk(25, sum(count_over_time({container=\"rts-caddy\"} | json | __error__=\"\" [1h])) by (request_uri))", "format": "table", "instant": true, "refId": "A" }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "indexByName": { "request_uri": 0, "Value": 1 } } }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["raid-team-stats", "rts", "http"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
