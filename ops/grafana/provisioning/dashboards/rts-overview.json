{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP request rate (req/s)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum(rate(rts_http_request_duration_seconds_count[1m])) by (route_class)",
          "legendFormat": "{{route_class}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP p95 latency (s)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rts_http_request_duration_seconds_bucket[5m])) by (le, route_class))",
          "legendFormat": "p95 {{route_class}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Rate-limit denials (1h)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        { "expr": "increase(rts_http_rate_limited_total[1h])", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Auth events",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(rts_auth_events_total[5m])) by (event)",
          "legendFormat": "{{event}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Queue depth (waiting + delayed)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 5,
      "targets": [
        {
          "expr": "rts_queue_depth",
          "legendFormat": "{{queue}} / {{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "BullMQ job throughput",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 6,
      "targets": [
        {
          "expr": "sum(rate(rts_jobs_total[5m])) by (queue, status)",
          "legendFormat": "{{queue}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Caddy access logs (5xx in last 15m)",
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "id": 7,
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{container=\"rts-caddy\"} |= \"5\" | json | status >= 500",
          "refId": "A"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Web app errors (pino level=error)",
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 34 },
      "id": 8,
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{container=\"rts-web\"} | json | level=\"error\"",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["raid-team-stats"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "RTS — Overview",
  "uid": "rts-overview",
  "version": 1,
  "weekStart": ""
